---
import AddToCalendarButton from "@components/add-to-calendar-button.astro";
import { Icon } from "astro-icon/components";
import { getLocaleUrl, useTranslations } from "@utils/i18n";
import { formatRange } from "@utils/helpers";
import { type BridgeEventEntry } from "@utils/event-bridge";
import type { CollectionEntry } from "astro:content";

interface Props {
  entries: CollectionEntry<'events'>[];
  locale: string;
  year: number;
}

const { entries, locale, year } = Astro.props as Props;
const t = useTranslations(locale);

// the month (1-12) an event belongs to within the selected year:
// events whose startDate is in a previous year are bucketed into January
const getMonth = (entry: CollectionEntry<'events'>) =>
  entry.data.startDate.getFullYear() < year ? 1 : entry.data.startDate.getMonth() + 1;

// group entries by month, keeping only months that actually have events, in ascending order
const months = [...new Set(entries.map(getMonth))].sort((a, b) => a - b);
const entriesByMonth = months.map((month) => ({
  month,
  monthEntries: entries.filter((entry) => getMonth(entry) === month),
}));
---

<div class="flex flex-col gap-8 sm:gap-10">
  {
    entriesByMonth.map(({ month, monthEntries }) => (
      <section>
        <h2 class="mb-4 text-xl font-bold sm:mb-6 sm:text-2xl">{t('pages.events.' + month)}</h2>
        <ul class="m-0 flex list-none flex-col gap-4 p-0 sm:gap-6">
          {monthEntries.map((entry) => (
            <li class="m-0">
              <a href={getLocaleUrl('events/detail/' + entry.id.split('/').slice(-1)[0], locale)} class="group xs:rounded-l-xl hover:border-primary block rounded-lg border border-transparent bg-white no-underline drop-shadow hover:drop-shadow-xl dark:bg-stone-800">
                <span class="group-hover:text-text dark:group-hover:text-text-dark flex">
                  <span class="xs:flex group-hover:bg-primary group-hover:text-primary-contrast hidden w-16 shrink-0 items-center justify-center rounded-l-lg bg-stone-700 px-4 text-lg font-bold text-white sm:w-20 sm:text-2xl dark:bg-stone-300 dark:text-stone-900">
                    {entry.data.startDate.getFullYear() < year ? <Icon name="heroicons:arrow-left" class="h-8 w-8" /> : entry.data.startDate.getDate()}
                  </span>
                  <span class="text-text dark:text-text-dark flex grow flex-col gap-2 px-5 py-4">
                    <span class="xs:text-xl text-lg font-semibold text-balance">{entry.data.title}</span>
                    <span class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm opacity-80">
                      <span class="flex items-start gap-1">
                        <Icon name="heroicons:calendar-days" class="mt-px h-4 w-4 shrink-0" />
                        {formatRange(entry.data.startDate, entry.data.endDate, entry.data.allDay, locale, String(year))}
                        {entry.data.rrule && <div class="self-center text-xs opacity-70">({t('pages.events.recurring')})</div>}
                      </span>
                      {entry.data.location && (
                        <span class="flex items-start gap-1">
                          <Icon name="heroicons:map-pin" class="mt-px h-4 w-4 shrink-0" />
                          {entry.data.location}
                        </span>
                      )}
                    </span>
                    {entry.data.description && <span class="xs:block mt-4 hidden text-sm font-normal sm:text-base">{entry.data.description}</span>}
                  </span>
                  <span class="z-40 m-4 hidden self-start lg:block" onclick="this.parentElement.addEventListener('click',function(e){e.preventDefault();e.stopPropagation();},{capture:true});">
                    <AddToCalendarButton
                      name={entry.data.title}
                      description={entry.data.description}
                      start={entry.data.startDate}
                      end={entry.data.endDate ?? entry.data.startDate}
                      allDay={entry.data.allDay ?? false}
                      timeZone={entry.data.timeZone}
                      location={entry.data.location}
                      rrule={entry.data.rrule}
                      icsFile={entry.data.icsFile}
                      language={locale}
                      organizer={entry.data.organizer}
                      prokey={(entry as BridgeEventEntry).prokey}
                      hideLabel
                      forceOverlay
                      buttonStyle="round"
                      listStyle="modal"
                      hideRichData
                    />
                  </span>
                  <Icon name="heroicons:arrow-right" class="mx-4 h-5 w-5 shrink-0 self-center lg:hidden" />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</div>
