---
import { getCleanLocaleUrl } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

interface Props {
  title: string;
  description?: string;
  image?: string;
  locale?: string;
  author?: {
    "@type": "Person" | "Organization";
    name: string;
    url?: string;
    image?: string;
  }
  publisher?: {
    "@type": "Person" | "Organization";
    name: string;
    url?: string;
    image?: string;
  }
}

const { title, description, image, locale } = Astro.props as Props;

const pageUrl = getCleanLocaleUrl(Astro.url, locale);

const author = Astro.props.author ? { "@context": "https://schema.org", ...(Astro.props.author) } : null;
const creator = author;
const publisher = Astro.props.publisher ? { "@context": "https://schema.org", ...(Astro.props.publisher) } : null;

const structuredData = {
  "@context": "https://schema.org",
  "@id": `${themeConfig.site}/#website`,
  "@type": "WebSite",
  name: title,
  ...(description && { about: description }),
  url: pageUrl,
  ...(image && { image }),
  author,
  creator,
  publisher,
}
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
