---
import { Icon } from "astro-icon/components";
import Reveal from "@components/reveal.astro";
import { useTranslations, getLocaleUrl } from "@utils/i18n";
import { themeConfig } from "~/theme.config";
import interstitialVideo from "@images/interstitial.mp4";

interface Props {
  locale?: string;
}

const { locale = themeConfig.i18n.defaultLocale } = Astro.props;
const t = useTranslations(locale);

interface FeatureCard {
  slug: string;
  icon: string;
  accent: "primary" | "secondary";
}

const features: FeatureCard[] = [
  { slug: "feature-ai", icon: "heroicons:sparkles", accent: "primary" },
  { slug: "feature-speed", icon: "heroicons:bolt", accent: "primary" },
  { slug: "feature-theme", icon: "heroicons:swatch", accent: "secondary" },
  { slug: "feature-i18n", icon: "heroicons:language", accent: "secondary" },
  { slug: "feature-content", icon: "heroicons:rectangle-stack", accent: "primary" },
  { slug: "feature-dx", icon: "heroicons:command-line", accent: "secondary" },
];

interface Voice {
  slug: string;
  initials: string;
  tint: string;
}

const voices: Voice[] = [
  { slug: "voice-1", initials: "MV", tint: "from-purple-500 to-indigo-500" },
  { slug: "voice-2", initials: "DP", tint: "from-orange-500 to-rose-500" },
  { slug: "voice-3", initials: "LR", tint: "from-emerald-500 to-teal-500" },
  { slug: "voice-4", initials: "TA", tint: "from-sky-500 to-blue-600" },
];

interface UseCase {
  slug: string;
  icon: string;
}

const useCases: UseCase[] = [
  { slug: "usecase-portfolio", icon: "heroicons:user-circle" },
  { slug: "usecase-company", icon: "heroicons:building-office-2" },
  { slug: "usecase-saas", icon: "heroicons:rocket-launch" },
  { slug: "usecase-listing", icon: "heroicons:rectangle-group" },
];

const docsUrl = getLocaleUrl("docs", locale);
const featuresUrl = getLocaleUrl("features", locale);
---

<section class="home-content flex flex-col">
  <!-- ── Feature cards ── -->
  <div class="graph-paper-bg-outer">
    <div class="container mx-auto py-20">
      <section aria-labelledby="home-features-heading">
        <Reveal class="mb-12 flex flex-col items-center gap-3 text-center">
          <span class="text-primary dark:text-primary-light text-sm font-semibold tracking-[0.2em] uppercase">
            {t('home-content.features-eyebrow')}
          </span>
          <h2 id="home-features-heading" class="text-3xl font-bold sm:text-4xl">
            {t('home-content.features-heading')}
          </h2>
          <p class="max-w-2xl text-stone-600 dark:text-stone-300">
            {t('home-content.features-sub')}
          </p>
        </Reveal>

        <ul class="m-0 grid list-none grid-cols-1 gap-5 p-0 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map((feature, i) => (
              <Reveal as="li" delay={i * 70} from="up" class="m-0">
                <article class="feature-card group relative h-full overflow-hidden rounded-xl border border-stone-300 bg-white p-6 transition-all hover:-translate-y-1 hover:shadow-xl dark:border-stone-700 dark:bg-stone-900">
                  <div class={`absolute inset-x-0 top-0 h-1 ${feature.accent === 'primary' ? 'bg-primary' : 'bg-secondary'}`} />
                  <span class={`mb-4 flex h-11 w-11 items-center justify-center rounded-lg ${feature.accent === 'primary' ? 'bg-primary-light/15 text-primary dark:bg-primary-darker dark:text-primary-light' : 'bg-secondary-light/15 text-secondary dark:bg-secondary-dark dark:text-white/60'}`}>
                    <Icon name={feature.icon} class="h-6 w-6" aria-hidden="true" />
                  </span>
                  <h3 class="mb-2 text-lg font-bold">{t(`home-content.${feature.slug}-title`)}</h3>
                  <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-300">{t(`home-content.${feature.slug}-text`)}</p>
                </article>
              </Reveal>
            ))
          }
        </ul>
      </section>
    </div>
  </div>

  <!-- ── Parallax Video ── -->
  <div class="parallax-video hidden md:block" data-parallax-video>
    <div class="parallax-video__pin">
      <video class="parallax-video__media" data-parallax-video-el data-src={interstitialVideo} muted playsinline preload="none" aria-hidden="true"></video>
      <div class="parallax-video__overlay">
        <Reveal class="flex flex-col items-center gap-3 px-6 text-center">
          <span class="text-sm font-semibold tracking-[0.2em] text-white/80 uppercase">
            {t('home-content.parallax-eyebrow')}
          </span>
          <h2 class="text-3xl font-bold text-white drop-shadow-lg sm:text-4xl">
            {t('home-content.parallax-heading')}
          </h2>
        </Reveal>
      </div>
    </div>
  </div>

  <!-- ── Customer voices ── -->
  <div class="container mx-auto py-20">
    <section aria-labelledby="home-voices-heading">
      <Reveal class="mb-12 flex flex-col items-center gap-3 text-center">
        <span class="text-primary dark:text-primary-light text-sm font-semibold tracking-[0.2em] uppercase">
          {t('home-content.voices-eyebrow')}
        </span>
        <h2 id="home-voices-heading" class="text-3xl font-bold sm:text-4xl">
          {t('home-content.voices-heading')}
        </h2>
        <p class="max-w-2xl text-stone-600 dark:text-stone-300">
          {t('home-content.voices-sub')}
        </p>
      </Reveal>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          voices.map((voice, i) => (
            <Reveal delay={i * 70} from="up">
              <figure class="voice-card flex h-full flex-col gap-4 rounded-xl border border-stone-300 bg-white p-6 dark:border-stone-700 dark:bg-stone-900">
                <Icon name="heroicons:chat-bubble-left-right" class="h-6 w-6 text-stone-300 dark:text-stone-600" aria-hidden="true" />
                <blockquote class="grow text-sm leading-relaxed text-stone-700 dark:text-stone-200">"{t(`home-content.${voice.slug}-quote`)}"</blockquote>
                <figcaption class="flex items-center gap-3">
                  <span class={`flex h-10 w-10 items-center justify-center rounded-full bg-linear-to-br ${voice.tint} text-sm font-bold text-white`}>{voice.initials}</span>
                  <span class="flex flex-col">
                    <span class="text-sm font-semibold">{t(`home-content.${voice.slug}-name`)}</span>
                    <span class="text-xs text-stone-500 dark:text-stone-400">{t(`home-content.${voice.slug}-role`)}</span>
                  </span>
                </figcaption>
              </figure>
            </Reveal>
          ))
        }
      </div>
    </section>
  </div>

  <!-- ── Use cases ── -->
  <div class="graph-paper-bg-inner">
    <div class="container mx-auto py-20">
      <section aria-labelledby="home-usecases-heading">
        <Reveal class="mb-12 flex flex-col items-center gap-3 text-center">
          <span class="text-primary dark:text-primary-light text-sm font-semibold tracking-[0.2em] uppercase">
            {t('home-content.usecases-eyebrow')}
          </span>
          <h2 id="home-usecases-heading" class="text-3xl font-bold sm:text-4xl">
            {t('home-content.usecases-heading')}
          </h2>
          <p class="max-w-2xl text-stone-600 dark:text-stone-300">
            {t('home-content.usecases-sub')}
          </p>
        </Reveal>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          {
            useCases.map((uc, i) => (
              <Reveal delay={i * 70} from={i % 2 === 0 ? 'left' : 'right'}>
                <article class="usecase-card group hover:border-primary dark:hover:border-primary-light flex h-full items-start gap-5 rounded-xl border border-stone-300 bg-white p-6 transition-all hover:shadow-lg dark:border-stone-700 dark:bg-stone-900">
                  <span class="bg-primary-light/15 text-primary dark:bg-primary-darker dark:text-primary-light flex h-12 w-12 shrink-0 items-center justify-center rounded-lg">
                    <Icon name={uc.icon} class="h-6 w-6" aria-hidden="true" />
                  </span>
                  <div class="flex flex-col gap-2">
                    <h3 class="text-lg font-bold">{t(`home-content.${uc.slug}-title`)}</h3>
                    <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-300">{t(`home-content.${uc.slug}-text`)}</p>
                  </div>
                </article>
              </Reveal>
            ))
          }
        </div>
      </section>
    </div>
  </div>

  <!-- ── CTA ── -->
  <div class="container mx-auto py-20">
    <div class="cta-band border-primary/20 from-primary-light/10 to-secondary-light/10 dark:from-primary-darker/30 dark:to-secondary-dark/20 relative overflow-hidden rounded-2xl border-4 bg-linear-to-br via-white px-6 py-12 text-center sm:px-12 dark:via-stone-900">
      <div class="cta-glow pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto flex max-w-2xl flex-col items-center gap-4">
        <h2 class="text-3xl font-bold sm:text-4xl">{t('home-content.cta-heading')}</h2>
        <p class="max-w-xl text-stone-600 dark:text-stone-300">
          {t('home-content.cta-sub')}
        </p>
        <div class="mt-2 flex flex-wrap items-center justify-center gap-4">
          <a href={docsUrl} class="btn-primary group">
            {t('home-content.cta-primary')}
            <Icon name="heroicons:arrow-right" class="mr-1 ml-0 h-4 w-4 transition-all duration-200 group-hover:mr-0 group-hover:ml-1" aria-hidden="true" />
          </a>
          <a href={featuresUrl} class="btn-subtle group rounded px-4 py-[0.43rem]">
            <span>{t('home-content.cta-secondary')}</span>
            <Icon name="heroicons:arrow-right" class="mr-1 ml-0 h-4 w-4 transition-all duration-200 group-hover:mr-0 group-hover:ml-1" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../styles/tailwind.config.css";

  /* ── CTA glow ── */
  .cta-glow {
    background: radial-gradient(ellipse at 50% 0%, rgba(80, 22, 138, 0.18) 0%, transparent 60%);
  }
  :global(.dark) .cta-glow {
    background: radial-gradient(ellipse at 50% 0%, rgba(242, 100, 48, 0.16) 0%, transparent 60%);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }

  .graph-paper-bg-outer,
  .graph-paper-bg-inner {
    position: relative;
  }

  .graph-paper-bg-outer::before,
  .graph-paper-bg-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: linear-gradient(rgba(212, 212, 212, 0.69) 2px, transparent 2px), linear-gradient(90deg, rgba(212, 212, 212, 0.69) 2px, transparent 2px), linear-gradient(rgba(212, 212, 212, 0.69) 1px, transparent 1px), linear-gradient(90deg, rgba(212, 212, 212, 0.69) 1px, rgba(247, 247, 252, 0) 1px);
    background-size:
      100px 100px,
      100px 100px,
      20px 20px,
      20px 20px;
    background-position:
      -2px -2px,
      -2px -2px,
      -1px -1px,
      -1px -1px;
  }

  /* In dark mode the light grid lines would be too bright, so dim them. */
  :global(.dark) .graph-paper-bg-outer::before,
  :global(.dark) .graph-paper-bg-inner::before {
    background-image: linear-gradient(rgba(80, 80, 80, 0.3) 2px, transparent 2px), linear-gradient(90deg, rgba(80, 80, 80, 0.3) 2px, transparent 2px), linear-gradient(rgba(80, 80, 80, 0.22) 1px, transparent 1px), linear-gradient(90deg, rgba(80, 80, 80, 0.22) 1px, rgba(247, 247, 252, 0) 1px);
  }

  .graph-paper-bg-outer::before {
    mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.6) 100%);
    -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.6) 100%);
    mask-size: 100% 100%;
    -webkit-mask-size: 100% 100%;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
  }

  .graph-paper-bg-inner::before {
    mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 75%);
    mask-size: 100% 100%;
    -webkit-mask-size: 100% 100%;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
  }

  .graph-paper-bg-outer > *,
  .graph-paper-bg-inner > * {
    position: relative;
    z-index: 1;
  }

  /* ── Parallax video ── */
  /*
    The outer element is tall (acts as the scroll track). Its pinned child stays
    fixed in the viewport while the track scrolls past, giving the parallax feel
    of the page scrolling *over* a static video.
  */
  .parallax-video {
    position: relative;
    height: 200vh; /* track length: video stays pinned for one extra viewport */
  }

  .parallax-video__pin {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .parallax-video__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .parallax-video__overlay {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* Subtle darkening so the overlay text stays readable over the video. */
  .parallax-video__pin::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.55));
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .parallax-video {
      height: auto;
    }
    .parallax-video__pin {
      position: relative;
      top: auto;
      height: 70vh;
    }
  }
</style>

<script>
  /**
   * Scroll-driven parallax video.
   *
   * - Only activates on viewports wider than 768px (the section is hidden below
   *   that via CSS, and we double-check here before touching the video).
   * - The video source is assigned here (not in markup) so no bytes are fetched
   *   on mobile or when JS is off.
   * - Playback progress is mapped to the section's scroll progress: at the top
   *   of the track the video is at frame 0, at the bottom it's at the end.
   * - Respects prefers-reduced-motion: loads the video but leaves it on the
   *   first frame (CSS also disables the sticky pin in that case).
   */
  function setupParallaxVideo() {
    const root = document.querySelector<HTMLElement>('[data-parallax-video]');
    const video = root?.querySelector<HTMLVideoElement>('[data-parallax-video-el]');
    if (!root || !video) return;

    // Hard gate: never load the video on small screens.
    if (!window.matchMedia('(min-width: 769px)').matches) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Assign the source now that we know we're on a wide viewport.
    const src = video.dataset.src;
    if (!src) return;
    video.src = src;
    // Load enough to seek without starting playback.
    video.load();

    const track = root;
    const media = video;
    let rafId = 0;

    function updateProgress() {
      rafId = 0;
      if (!media.duration) return;
      const rect = track.getBoundingClientRect();
      // Progress 0 → 1 as the track scrolls from entering to leaving the viewport.
      const trackLen = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), trackLen);
      const progress = trackLen > 0 ? scrolled / trackLen : 0;
      try {
        media.currentTime = progress * media.duration;
      } catch {
        /* seeking can throw before metadata is loaded - ignore */
      }
    }

    function onScroll() {
      if (rafId) return;
      rafId = requestAnimationFrame(updateProgress);
    }

    function bind() {
      if (prefersReducedMotion) {
        // Leave the video on its first frame; nothing to drive.
        return;
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      media.addEventListener('loadedmetadata', updateProgress);
      updateProgress();
    }

    // Defer binding until the video has metadata so seeking works.
    if (media.readyState >= 1) {
      bind();
    } else {
      media.addEventListener('loadedmetadata', bind, { once: true });
    }
  }

  document.addEventListener('astro:page-load', setupParallaxVideo);
</script>
