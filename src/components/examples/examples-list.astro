---
/**
 * ExamplesList
 *
 * Renders the directory of websites built with Stardrive. The entries live in
 * `src/data/examples.json` so anyone can add their site via a simple pull
 * request. The list is sorted alphabetically by title and grouped into sections
 * by first letter; empty letters are skipped.
 */
import { Icon } from "astro-icon/components";
import examplesData from "@data/examples.json";

interface Site {
  title: string;
  description: string;
  url: string;
}

interface Props {
  /** Label for the "no entries yet" empty state. */
  emptyText: string;
  /** Accessible label for the whole listing. */
  listLabel: string;
}

const { emptyText, listLabel } = Astro.props;

// Determine the section letter for a title: first A-Z letter, otherwise "#".
function sectionKey(title: string): string {
  const first = title.trim().charAt(0).toUpperCase();
  return /[A-Z]/.test(first) ? first : "#";
}

const sites = (examplesData.sites as Site[])
  .slice()
  .sort((a, b) => a.title.localeCompare(b.title, "en", { sensitivity: "base" }));

// Group into ordered sections, skipping empty letters entirely.
const groups = new Map<string, Site[]>();
for (const site of sites) {
  const key = sectionKey(site.title);
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(site);
}
const sections = Array.from(groups.entries()).sort(([a], [b]) => a.localeCompare(b, "en"));
---

{
  sites.length === 0 ? (
    <p class="rounded-lg border border-dashed border-stone-300 bg-stone-100 p-8 text-center text-stone-600 dark:border-stone-700 dark:bg-stone-800 dark:text-stone-300">{emptyText}</p>
  ) : (
    <div class="flex flex-col gap-12" aria-label={listLabel}>
      {sections.map(([letter, entries]) => (
        <section aria-labelledby={`examples-section-${letter}`}>
          <div class="mb-5 flex items-center gap-4">
            <span id={`examples-section-${letter}`} class="font-headline text-primary/80 dark:text-primary-light/80 text-5xl font-bold select-none sm:text-6xl" aria-hidden="true">
              {letter}
            </span>
            <span class="h-px grow bg-stone-300 dark:bg-stone-700" aria-hidden="true" />
          </div>
          <ul class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2">
            {entries.map((site) => (
              <li class="m-0">
                <a href={site.url} target="_blank" rel="noopener" class="group ring-primary hover:border-primary dark:hover:border-primary-light flex h-full flex-col gap-2 rounded-lg border border-stone-300 bg-white p-5 no-underline ring-offset-white outline-0 transition-shadow focus-within:ring-offset-2 hover:shadow-md dark:border-stone-700 dark:bg-stone-900 dark:ring-offset-black">
                  <span class="flex items-center justify-between gap-2">
                    <span class="group-hover:text-primary dark:group-hover:text-primary-light text-lg font-bold">{site.title}</span>
                    <Icon name="heroicons:arrow-up-right" class="group-hover:text-primary dark:group-hover:text-primary-light h-5 w-5 shrink-0 text-stone-400 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true" />
                  </span>
                  <span class="text-sm font-normal text-stone-600 dark:text-stone-300">{site.description}</span>
                  <span class="mt-auto pt-2 text-xs text-stone-400 dark:text-stone-500">{site.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )
}
