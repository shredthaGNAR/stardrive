---
import { getCleanLocaleUrl } from "@utils/i18n";
import { themeConfig } from '~/theme.config';
import { THEME_INIT_SCRIPT } from '@utils/themeSwitch';

interface Props {
  locale: string;
  title: string;
  description: string;
  robots?: string;
  isError?: boolean;
  externalCanonical?: string;
}

const { locale, title, description, isError, externalCanonical } = Astro.props as Props;
const robots = Astro.props.robots || themeConfig.robots || "noindex, nofollow";

const canonical = externalCanonical || getCleanLocaleUrl(Astro.url, locale);
---

<!-- theme init: runs synchronously before first paint to prevent flash --><!-- prettier-ignore -->
<script is:inline set:html={THEME_INIT_SCRIPT}></script>
<script>
  // Persist the current locale to localStorage on every page load to have it available at client side scripts
  import { set } from '@utils/localStorage';
  document.addEventListener('astro:page-load', () => {
    const locale = document.documentElement.lang;
    if (locale) {
      void set('locale', locale);
    }
  });
</script>
<!-- technical -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
<meta name="generator" content="Astro Stardrive" />
<!-- icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<!-- dynamic for light and dark mode -->
<link rel="shortcut icon" href="/favicon.ico" sizes="48x48" />
<link rel="shortcut icon" href="/favicon-dark-mode.ico" sizes="48x48" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/png" href="/favicon-96x96-dark-mode.png" sizes="96x96" media="(prefers-color-scheme: dark)" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<!-- web app -->
<meta name="apple-mobile-web-app-title" content={themeConfig.shortName || themeConfig.name || new URL(themeConfig.site).hostname} />
{themeConfig.generateWebmanifest ? <link rel="manifest" href="/site.webmanifest" /> : ''}
<meta name="theme-color" content={themeConfig.themeColor || themeConfig.primaryColor} />
<!-- descriptive -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<!-- urls -->
<link rel="sitemap" href="/sitemap-index.xml" />
{!isError ? <link rel="canonical" href={canonical} /> : ''}
