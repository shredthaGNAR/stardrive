---
import { Icon } from "astro-icon/components";
import SocialShare from "@components/blog/social-share.astro";
import type { CollectionEntry } from "astro:content";
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import CatTagList from "@components/blog/cat-tag-list.astro";
import ListItem from "@components/blog/list-item.astro";
import TableOfContents from "@components/blog/table-of-contents.astro";
import { useTranslations, getCleanLocaleUrl} from "@utils/i18n";
import { themeConfig } from '~/theme.config';
import { getReadingTime } from '@utils/reading-time';

interface Props {
  entry: CollectionEntry<'articles'>;
  prev?: CollectionEntry<'articles'>;
  next?: CollectionEntry<'articles'>;
  locale: string;
  imageFile?: ImageMetadata;
}

const { entry, locale, prev, next, imageFile } = Astro.props as Props;
const t = useTranslations(locale);

const formattedpublishDateLong = entry.data.publishDate.toLocaleString(locale, { dateStyle: 'long' });
const formattedpublishDate = entry.data.publishDate.toLocaleString(locale, { dateStyle: 'short' });
const formattedUpdateDate = entry.data.updateDate?.toLocaleString(locale, { dateStyle: 'short' });
const { Content, headings } = await render(entry);
const tocDepth = entry.data.tocDepth || themeConfig.articles?.tocMaxDepth || 3;
const reducedHeadings = headings.filter(({ depth }: { depth: number }) => depth <= tocDepth);

const articleUrl = getCleanLocaleUrl(Astro.url, locale);

const authorName = themeConfig.articles?.defaults?.author?.name ? themeConfig.articles.defaults.author.name : entry.data.author?.name;
const authorUrl = themeConfig.articles?.defaults?.author?.url ? themeConfig.articles.defaults.author.url : entry.data.author?.url;

const hideToC = tocDepth === 0 || reducedHeadings.length === 0;
---

<div id="start" class="flex flex-col">
  {imageFile ? <Image src={imageFile} alt={entry.data.image?.alt ? entry.data.image?.alt : ''} id="title-image" transition:name={'image-' + entry.id} draggable="false" priority /> : entry.data.image?.url ? <Image src={entry.data.image.url} alt={entry.data.image?.alt ? entry.data.image?.alt : ''} id="title-image" transition:name={'image-' + entry.id} draggable="false" priority inferSize /> : null}

  <h1 class="max-w-3xl px-2 text-3xl font-bold italic select-none sm:py-5 sm:text-5xl md:px-6">{entry.data.title}</h1>

  <div class="mt-3 flex w-full justify-start px-2 md:order-first md:mt-0 md:mb-3 md:justify-end">
    <div class="flex w-fit flex-wrap gap-5 rounded-lg text-xs text-stone-600 dark:text-stone-400">
      {
        authorName && (
          <div class="flex items-center gap-1" aria-label={t('labels.author')}>
            <Icon name="heroicons:user" class="h-3 w-3" />
            {authorUrl ? (
              <a href={authorUrl} target="_blank" rel="noopener noreferrer" class="font-normal text-inherit no-underline hover:underline">
                {authorName}
              </a>
            ) : (
              authorName
            )}
          </div>
        )
      }
      {
        formattedpublishDate && (
          <div class="flex items-center gap-1" aria-label={t('labels.published')}>
            <Icon name="heroicons:calendar-days" class="h-3 w-3" />
            {formattedpublishDate && formattedUpdateDate ? formattedpublishDate : formattedpublishDateLong}
          </div>
        )
      }
      {
        formattedUpdateDate && (
          <div class="flex items-center gap-1" aria-label={t('labels.updated')}>
            <Icon name="heroicons:pencil" class="h-3 w-3" />
            {formattedUpdateDate}
          </div>
        )
      }
      <div class="hidden items-center gap-1 sm:flex" aria-label={getReadingTime(entry.body) + ' ' + t('labels.min-read')}>
        <Icon name="heroicons:clock" class="h-3 w-3" />
        {getReadingTime(entry.body) + ' ' + t('labels.min-read')}
      </div>
    </div>
  </div>
</div>

<div class="relative flex gap-4 xl:gap-6">
  <div class="markdown-content relative mt-14 w-full border-stone-300 px-3 py-3 text-left leading-7 sm:rounded-lg sm:border sm:px-6 sm:py-5 md:px-8 md:py-7 lg:rounded-xl dark:border-stone-700">
    <button aria-label={t('labels.toc')} id="open-toc" class="btn-subtle float-right mb-8 ml-6 rounded-full lg:hidden">
      <Icon name="heroicons:list-bullet" class="h-8 w-8" />
    </button>
    <Content />
    <div class="mt-14 flex flex-col flex-wrap gap-6 border-t border-stone-300 pt-8 dark:border-stone-700">
      <CatTagList entries={entry.data.categories} {locale} type="categories" small={true} />
      <CatTagList entries={entry.data.tags} {locale} type="tags" small={true} />
    </div>
  </div>
  {
    !hideToC && (
      <side class="group/whole-toc text-text dark:text-text-dark sticky top-20 mt-14 mb-5 hidden h-fit w-fit max-w-56 grow rounded-lg border border-stone-400 text-left leading-7 lg:block dark:border-stone-700">
        <TableOfContents headings={reducedHeadings} {locale} />
      </side>
    )
  }
</div>

{
  themeConfig.articles?.social.buttons && Object.keys(themeConfig.articles.social.buttons).length > 0 && (
    <div class="mt-20 flex flex-wrap gap-x-8 gap-y-4">
      <h2 class="text-2xl font-bold italic opacity-60 select-none sm:text-3xl">{t('labels.share-article')}:</h2>
      <SocialShare url={articleUrl} title={entry.data.title} emailSubject={t('labels.share-email-subject')} {locale} />
    </div>
  )
}

{
  prev || next ? (
    <div class="mt-20">
      <h2 class="mb-5 text-2xl font-bold italic opacity-60 select-none sm:text-3xl">{t('labels.continue-reading')}:</h2>
      <div class="grid max-w-3xl grid-cols-1 gap-4 sm:grid-cols-2">
        {prev && <ListItem entry={prev} {locale} noTransition={true} />}
        {next && <ListItem entry={next} {locale} noTransition={true} />}
      </div>
    </div>
  ) : null
}

{
  !hideToC && (
    <div id="toc-overlay" class="text-text dark:text-text-dark top-0 left-0 z-50 hidden h-full w-full bg-linear-to-tr from-stone-200 to-stone-50 dark:from-stone-950 dark:to-stone-700">
      <button id="close-toc" aria-label={t('labels.close-menu')} class="btn-subtle absolute top-5 right-5 rounded-full">
        <Icon name="heroicons:x-mark" class="h-5 w-5 md:h-8 md:w-8" />
      </button>
      <div class="h-full w-full overflow-y-auto select-none">
        <div class="container mx-auto flex min-h-full w-full max-w-sm flex-col items-start justify-center py-8 sm:items-center">
          <TableOfContents headings={reducedHeadings} {locale} overlay={true} />
        </div>
      </div>
    </div>
  )
}

<script>
  const getFocusable = () => {
    const el = document.getElementById('toc-overlay');
    if (!el) return [];
    return Array.from(el.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'));
  };

  const trapFocus = (event: KeyboardEvent) => {
    const tocOverlay = document.getElementById('toc-overlay');
    if (!tocOverlay || tocOverlay.classList.contains('hidden')) return;
    if (event.key !== 'Tab') return;

    const focusable = getFocusable();
    if (!focusable.length) return;

    event.preventDefault();
    const current = document.activeElement;
    const index = focusable.indexOf(current as HTMLElement);
    if (event.shiftKey) {
      const prev = index <= 0 ? focusable.length - 1 : index - 1;
      focusable.at(prev)?.focus();
    } else {
      const next = index === -1 || index === focusable.length - 1 ? 0 : index + 1;
      focusable.at(next)?.focus();
    }
  };

  const openToC = () => {
    const tocOverlay = document.getElementById('toc-overlay');
    if (tocOverlay) {
      tocOverlay.classList.remove('hidden');
      tocOverlay.classList.add('fixed');
      document.body.classList.add('overflow-y-hidden');
      // Focus the first focusable element inside the overlay
      const focusable = getFocusable();
      focusable.at(0)?.focus();
    }
  };

  const closeToC = () => {
    const tocOverlay = document.getElementById('toc-overlay');
    if (!tocOverlay || tocOverlay.classList.contains('hidden')) return;
    tocOverlay.classList.add('hidden');
    tocOverlay.classList.remove('fixed');
    document.body.classList.remove('overflow-y-hidden');
    (document.getElementById('open-toc') as HTMLElement | null)?.focus();
  };

  const handleKeyup = (event: KeyboardEvent) => {
    if (event.key === 'Escape') closeToC();
  };

  const setupToC = () => {
    document.getElementById('open-toc')?.addEventListener('click', openToC);
    document.getElementById('close-toc')?.addEventListener('click', closeToC);
    document.addEventListener('keyup', handleKeyup);
    document.addEventListener('keydown', trapFocus);
    document.querySelectorAll('.toc-link').forEach((link) => link.addEventListener('click', closeToC));
  };

  const cleanupToC = () => {
    document.getElementById('open-toc')?.removeEventListener('click', openToC);
    document.getElementById('close-toc')?.removeEventListener('click', closeToC);
    document.removeEventListener('keyup', handleKeyup);
    document.removeEventListener('keydown', trapFocus);
    document.querySelectorAll('.toc-link').forEach((link) => link.removeEventListener('click', closeToC));
  };

  // astro:page-load fires on initial load and after every view-transition swap.
  document.addEventListener('astro:page-load', setupToC);
  document.addEventListener('astro:before-swap', cleanupToC);
</script>
