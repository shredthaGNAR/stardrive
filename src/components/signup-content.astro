---
/**
 * SignupContent
 *
 * Placeholder content for the signup page. The Stardrive boilerplate ships this
 * page intentionally empty: depending on the project, this is where you would
 * embed a real form, add marketing copy, or redirect visitors to a dedicated
 * web app. Shared between the default-locale and the `[lang]` signup routes.
 */
import { Icon } from "astro-icon/components";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from "~/theme.config";

interface Props {
  locale?: string;
}

const { locale = themeConfig.i18n.defaultLocale } = Astro.props;
const t = useTranslations(locale);

const options = [
  { icon: "heroicons:document-text", title: "pages.signup.option-form-title", text: "pages.signup.option-form-text" },
  { icon: "heroicons:megaphone", title: "pages.signup.option-marketing-title", text: "pages.signup.option-marketing-text" },
  { icon: "heroicons:arrow-top-right-on-square", title: "pages.signup.option-redirect-title", text: "pages.signup.option-redirect-text" },
];
---

<section class="mx-auto max-w-3xl">
  <p class="mb-10 text-lg text-stone-600 dark:text-stone-300">{t('pages.signup.intro')}</p>

  <ul class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-3">
    {
      options.map((option) => (
        <li class="m-0">
          <div class="flex h-full flex-col gap-3 rounded-lg border border-stone-300 bg-white p-5 dark:border-stone-700 dark:bg-stone-900">
            <span class="bg-primary/15 text-primary dark:bg-primary-darker dark:text-primary-light flex h-11 w-11 items-center justify-center rounded-lg">
              <Icon name={option.icon} class="h-6 w-6" aria-hidden="true" />
            </span>
            <h2 class="text-lg font-bold">{t(option.title)}</h2>
            <p class="text-sm text-stone-600 dark:text-stone-300">{t(option.text)}</p>
          </div>
        </li>
      ))
    }
  </ul>

  <div class="mt-10 flex items-start gap-3 rounded-lg border border-amber-400/50 bg-amber-100/60 p-4 dark:border-amber-500/40 dark:bg-amber-950/40" role="note">
    <Icon name="heroicons:information-circle" class="mt-0.5 h-5 w-5 shrink-0 text-amber-700 dark:text-amber-300" aria-hidden="true" />
    <p class="text-sm text-stone-700 dark:text-stone-200">{t('pages.signup.demo-note')}</p>
  </div>
</section>
