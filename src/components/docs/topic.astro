---
import { Icon } from "astro-icon/components";
import "@styles/docs.css";

/**
 * Topic
 *
 * Interactive, collapsible section used to build the guide page.
 * Renders as a native `<details>` element (so it works without JavaScript and is keyboard accessible) with an icon, a title, a short tagline and rich slot content.
 */

interface Props {
  /** Heroicons name, e.g. "heroicons:newspaper". */
  icon: string;
  title: string;
  /** Short one-line summary shown next to the title. */
  tagline?: string;
  /** Whether the topic starts expanded. */
  open?: boolean;
  class?: string;
}

const { icon, title, tagline, open = false, class: className = "" } = Astro.props;
---

<details class:list={['docs-topic group rounded-lg border border-stone-300 bg-white transition-shadow open:shadow-md hover:shadow-md dark:border-stone-700 dark:bg-stone-900', className]} open={open}>
  <summary class="flex cursor-pointer list-none items-center gap-4 p-4 select-none sm:p-5">
    <span class="bg-primary/15 text-primary group-open:bg-primary group-open:text-primary-contrast dark:bg-primary-darker dark:text-primary-light dark:group-open:bg-primary dark:group-open:text-primary-contrast flex h-11 w-11 shrink-0 items-center justify-center rounded-lg transition-colors">
      <Icon name={icon} class="h-6 w-6" aria-hidden="true" />
    </span>
    <span class="flex min-w-0 grow flex-col">
      <span class="text-lg font-bold">{title}</span>
      {tagline && <span class="text-sm text-stone-600 dark:text-stone-300">{tagline}</span>}
    </span>
    <Icon name="heroicons:chevron-down" class="group-hover:text-primary h-5 w-5 shrink-0 text-stone-400 transition-transform group-open:rotate-180" aria-hidden="true" />
  </summary>
  <div class="docs-topic-body border-t border-stone-200 px-4 pt-4 pb-5 sm:px-5 dark:border-stone-800">
    <slot />
  </div>
</details>

<style>
  .docs-topic summary::-webkit-details-marker {
    display: none;
  }
</style>
