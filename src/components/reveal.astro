---
/**
 * Reveal
 *
 * Wraps any content and fades/slides it into view once it enters the viewport.
 * Uses a single IntersectionObserver instance for all `.docs-reveal` elements on the page and fully respects `prefers-reduced-motion`.
 *
 * Purely decorative: if JavaScript is unavailable the content stays visible, because the "hidden" state is only applied by the script after mount.
 */

interface Props {
  /** Optional stagger delay in milliseconds (applied via inline style). */
  delay?: number;
  /** Extra classes for the wrapping element. */
  class?: string;
  /** Animation direction. Defaults to "up". */
  from?: "up" | "left" | "right" | "none";
  /** Rendered HTML tag. Defaults to "div". */
  as?: keyof HTMLElementTagNameMap;
}

const { delay = 0, class: className = "", from = "up", as = "div" } = Astro.props as Props;
const Tag = as;
---

<Tag class:list={['docs-reveal', className]} data-reveal-from={from} style={delay ? `--reveal-delay: ${delay}ms` : undefined}>
  <slot />
</Tag>

<style>
  .docs-reveal {
    transition:
      opacity 0.6s ease,
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }
  .docs-reveal.is-hidden {
    opacity: 0;
  }
  .docs-reveal.is-hidden[data-reveal-from='up'] {
    transform: translateY(2rem);
  }
  .docs-reveal.is-hidden[data-reveal-from='left'] {
    transform: translateX(-2rem);
  }
  .docs-reveal.is-hidden[data-reveal-from='right'] {
    transform: translateX(2rem);
  }
  @media (prefers-reduced-motion: reduce) {
    .docs-reveal,
    .docs-reveal.is-hidden {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  function setupReveal() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const elements = Array.from(document.querySelectorAll<HTMLElement>('.docs-reveal'));
    if (!elements.length) return;

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      elements.forEach((el) => el.classList.remove('is-hidden'));
      return;
    }

    // Hide first, then observe, so no-JS visitors always see the content.
    elements.forEach((el) => el.classList.add('is-hidden'));

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('is-hidden');
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
    );

    elements.forEach((el) => observer.observe(el));
  }

  document.addEventListener('astro:page-load', setupReveal);
</script>
