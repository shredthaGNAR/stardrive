---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import GetListedContent from "@components/examples/get-listed-content.astro";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

const locale = themeConfig.i18n.defaultLocale;
const t = useTranslations(locale);
---

<Layout title={t('pages.get-listed.title')} description={t('pages.get-listed.description')}>
  <Headline text={t('pages.get-listed.title')} class="pb-10" />
  <GetListedContent {locale} />
</Layout>
