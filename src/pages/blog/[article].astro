---
import Layout from "@layouts/article.astro";
import Single from "@components/blog/single.astro";
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from 'astro';
import { themeConfig } from '~/theme.config';
import { sortArticleList, getAdjacentArticles } from "@utils/blog";
import FallbackImage from "@images/content/articles-fallback.jpg";

export const prerender = false; // We opt out from prerendering, assuming that might be a lot of elements here, while running on Cloudflare worker. Change this, if your case is rather about a small amount of pages

export async function getStaticPaths() {
  const entries = await getCollection('articles', ({ id, data }) => {
    // only show articles that are not drafts
    return !data.draft && id.startsWith(themeConfig.i18n.defaultLocale + '/');
  }) as CollectionEntry<'articles'>[];
  const paths = entries.map((entry: CollectionEntry<'articles'>) => {
    return { params: { article: entry.id.split('/')[1] || undefined } };
  });
  return paths;
}

const locale = themeConfig.i18n.defaultLocale;
const entry = await getEntry('articles', locale + '/' + Astro.params.article as string) || {} as CollectionEntry<'articles'>;

// define image
const imageFile: ImageMetadata | undefined = entry.data.image?.file ? entry.data.image.file : (!entry.data.image?.url && themeConfig.articles?.imageFallback) ? FallbackImage : undefined;

// Get all articles for navigation
const allArticles = sortArticleList(await getCollection('articles', ({ id, data }) => {
  return !data.draft && id.startsWith(locale + '/');
}) as CollectionEntry<'articles'>[]);

// Find current article index
const currentIndex = allArticles.findIndex(article => article.id === entry.id);

// Get adjacent articles with fallback logic
const { prev, next } = getAdjacentArticles(currentIndex, allArticles) ?? { prev: undefined, next: undefined };

// Get heroImage filename
const articleImage = (function() {
  const url = imageFile?.src ? imageFile.src : entry.data.image?.url ? entry.data.image?.url : null;
  if (!url) return undefined;
  return url.split('/').pop()?.split('.')[0];
})();
---

<Layout title={entry.data.title} imgFallback={imageFile == FallbackImage} description={entry.data.excerpt} {articleImage} {locale}>
  <Single {entry} {locale} {prev} {next} {imageFile} />
</Layout>
