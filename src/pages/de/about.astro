---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import AboutContent from "@components/about/about-content.astro";
import { useTranslations } from "@utils/i18n";

const locale = 'de';
const t = useTranslations(locale);

// Jahre der Webentwicklung, gezählt von 2003 bis zum aktuellen Jahr.
const yearsBuilding = new Date().getFullYear() - 2003;

const content = {
  imageAlt: "Das Team hinter Astro Stardrive",
  lead: "Hi, ich bin Jens. Ich baue seit dem Jahr 2000 Websites - von ganz einfachem HTML damals über PHP und WordPress bis hin zu modernen Frameworks wie React, Angular und Vue. In Stardrive fließt all diese Erfahrung zusammen.",
  stats: [
    { icon: "heroicons:calendar-days", value: `${yearsBuilding}+ Jahre`, label: "im Web unterwegs" },
    { icon: "heroicons:code-bracket-square", value: "HTML → Astro", label: "die ganze Reise" },
    { icon: "heroicons:magnifying-glass", value: "SEO & Marketing", label: "direkt eingebaut" },
    { icon: "heroicons:lock-open", value: "Open Source", label: "MIT-lizenziert" },
  ],
  storyHeading: "Die Reise",
  timeline: [
    {
      year: "2003",
      title: "Angefangen mit reinem HTML",
      text: "Handgeschriebene Seiten, ein Texteditor und jede Menge Neugier. Das Web war einfach - und genau diese Einfachheit hat mir die Grundlagen beigebracht.",
    },
    {
      year: "Die PHP- & WordPress-Jahre",
      title: "Dynamische Seiten im großen Stil",
      text: "Serverseitig gerenderte Seiten, Content-Management und alles, was WordPress einem Projekt entgegenwerfen konnte. Mächtig, aber aufwendig in der Pflege.",
    },
    {
      year: "Moderne Frameworks",
      title: "React, Angular & Vue",
      text: "Die Komponenten-Ära. Reichhaltige Interaktivität, aber oft auf Kosten von Performance, Komplexität und langfristiger Wartung.",
    },
    {
      year: "Heute",
      title: "Astro bringt alles zusammen",
      text: "Meiner Meinung nach führt Astro die neuesten Entwicklungen zu etwas zusammen, das schlicht die beste Performance zu den geringsten Kosten und mit minimalem Wartungsaufwand liefert - und dabei die Wurzel von allem respektiert: native Web-Technologie. Zurück zu funktionierenden Grundlagen, statt Dinge zu verkomplizieren, und diese Grundlagen dann in die moderne Welt bringen. Das ist ein Trend unter echten Branchenprofis, und Astro vereint all das.",
    },
  ],
  highlightsHeading: "Warum es Stardrive gibt",
  highlights: [
    {
      icon: "heroicons:rocket-launch",
      title: "Entwicklung beschleunigen",
      text: "Ich habe Stardrive gebaut, um die ersten 36 Schritte jedes Projekts zu überspringen - ein starkes Fundament, auf dem du sofort aufbauen kannst.",
    },
    {
      icon: "heroicons:wrench-screwdriver",
      title: "Features & Utilities inklusive",
      text: "Viele kleine Utilities und Features, die Astro-Projekte schon ab dem ersten Commit noch besser machen.",
    },
    {
      icon: "heroicons:chart-bar",
      title: "Marketing- & SEO-Wissen",
      text: "Neben dem Engineering habe ich Marketing studiert und jahrelang in der SEO-Branche gearbeitet - dieses Wissen steckt in diesem Projekt.",
    },
    {
      icon: "heroicons:shield-check",
      title: "Best Practices von Haus aus",
      text: "Sicherheit, Barrierefreiheit, strukturierte Daten und Performance sind von Anfang an dabei, sodass du sie nicht nachträglich ergänzen musst.",
    },
  ],
  openSourceHeading: "In der Öffentlichkeit gebaut",
  openSourceText: "Stardrive ist Open Source, weil ich an die Kraft der Offenheit glaube - Feedback zu bekommen, Dinge wachsen zu sehen und dabei Mitwirkende zu finden. Wenn es dir hilft, eine bessere Website schneller zu veröffentlichen, ist genau das der Sinn der Sache.",
  authorCtaLabel: "Mehr über Jens",
};
---

<Layout title={t('pages.about.title')} description={t('pages.about.description')} {locale}>
  <Headline text={t('pages.about.title')} class="pb-10" />
  <AboutContent {...content} />
</Layout>
