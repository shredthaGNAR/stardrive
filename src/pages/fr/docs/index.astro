---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import { Icon } from "astro-icon/components";
import { Code } from "astro-expressive-code/components";
import Callout from "@components/docs/callout.astro";
import CodeTabs from "@components/docs/code-tabs.astro";
import Reveal from "@components/reveal.astro";
import { useTranslations, getLocaleUrl } from "@utils/i18n";

const locale = 'fr';
const t = useTranslations(locale);

const createCommands = [
  { label: "npm", code: "npm create stardrive@latest", lang: "sh" },
  { label: "pnpm", code: "pnpm create stardrive@latest", lang: "sh" },
  { label: "yarn", code: "yarn create stardrive@latest", lang: "sh" },
  { label: "bun", code: "bun create stardrive@latest", lang: "sh" },
];

const agentPrompt = `Démarre la configuration de ce nouveau projet Astro Stardrive.
Tiens compte du AGENTS.md et surtout du SETUP.md dans le dossier .ai.

Autres spécifications sur le projet que je veux construire :
[mets tes spécifications ici]`;
---

<Layout title={t('pages.docs.title-install')} description={t('pages.docs.description-install')} {locale}>
  <Headline text={t('pages.docs.title-install')} class="pb-6" />

  <p class="mb-12 max-w-2xl text-lg text-stone-600 dark:text-stone-300">Stardrive vous fait passer de zéro à un site web rapide, moderne et prêt pour l'IA en une seule commande. Choisissez le chemin qui vous convient et commencez à construire.</p>

  <!-- Chemin recommandé -->
  <Reveal class="mb-14">
    <div class="border-primary/20 rounded-xl border-4 bg-white p-6 sm:p-8 dark:bg-stone-900">
      <div class="mb-5 flex items-center gap-3">
        <span class="bg-primary text-primary-contrast flex h-10 w-10 items-center justify-center rounded-full">
          <Icon name="heroicons:rocket-launch" class="h-6 w-6" aria-hidden="true" />
        </span>
        <div>
          <p class="text-primary dark:text-primary-light text-sm font-semibold tracking-wide uppercase">Recommandé</p>
          <h2 class="text-2xl font-bold">Créer avec le starter</h2>
        </div>
      </div>
      <p class="mb-5 max-w-2xl text-stone-600 dark:text-stone-300">Le starter interactif génère le projet, vous laisse faire vos premiers choix et supprime pour vous tous les fichiers de démonstration. Utilisez le gestionnaire de paquets de votre choix :</p>
      <CodeTabs tabs={createCommands} title="Créer un nouveau projet Stardrive" />

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <Callout variant="tip" title="Options pratiques">
          <p>Ajoutez <code>--no-install</code> pour ignorer l'installation des dépendances, ou <code>--version X.X.X</code> pour fixer une version précise.</p>
        </Callout>
        <Callout variant="note" title="bun fonctionne aussi">
          <p>La commande <code>bun</code> fonctionne sans souci tant que Node.js est également installé.</p>
        </Callout>
      </div>
    </div>
  </Reveal>

  <!-- Démarrer avec un agent IA -->
  <Reveal delay={80} class="mb-14">
    <div class="border-secondary/30 bg-secondary-light/5 dark:border-secondary-light/40 dark:bg-secondary-dark/20 rounded-xl border p-6 sm:p-8">
      <div class="mb-5 flex items-center gap-3">
        <span class="bg-secondary text-secondary-contrast flex h-10 w-10 items-center justify-center rounded-full">
          <Icon name="heroicons:sparkles" class="h-6 w-6" aria-hidden="true" />
        </span>
        <h2 class="text-2xl font-bold">Démarrer avec un agent IA</h2>
      </div>
      <p class="mb-5 max-w-2xl text-stone-600 dark:text-stone-300">Stardrive est conçu pour l'ère de l'IA et se documente lui-même pour les agents de développement. Une fois le projet créé, confiez la configuration à votre assistant avec un prompt comme celui-ci :</p>
      <Code code={agentPrompt} lang="text" title="Prompt pour votre agent IA" />
      <div class="mt-6">
        <Callout variant="recommend" title="Ajoutez le MCP d'Astro">
          <p>
            Connecter le <a href="https://docs.astro.build/fr/guides/build-with-ai/#installation" class="external-link" target="_blank" rel="noopener">serveur MCP d'Astro</a> donne beaucoup plus de contexte à votre agent. Cela consomme plus de tokens, mais produit des résultats nettement meilleurs.
          </p>
        </Callout>
      </div>
    </div>
  </Reveal>

  <!-- Alternative : cloner -->
  <Reveal delay={120} class="mb-14">
    <div class="rounded-xl border border-stone-300 bg-white p-6 sm:p-8 dark:border-stone-700 dark:bg-stone-900">
      <div class="mb-5 flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-200 text-stone-700 dark:bg-stone-700 dark:text-stone-200">
          <Icon name="heroicons:code-bracket" class="h-6 w-6" aria-hidden="true" />
        </span>
        <h2 class="text-2xl font-bold">Alternative : forker ou cloner</h2>
      </div>
      <p class="mb-5 max-w-2xl text-stone-600 dark:text-stone-300">Vous préférez un contrôle total dès le départ ? Forkez ou clonez directement le dépôt officiel. Vous gérez alors vous-même le nettoyage initial - le guide de configuration vous accompagne.</p>
      <Code code="git clone https://github.com/Peltmonger/stardrive.git mon-projet" lang="sh" title="Cloner le dépôt" />
      <div class="mt-6">
        <Callout variant="warning" title="Nettoyage manuel requis">
          <p>
            Les clones directs contiennent encore des fichiers de démo et de dépôt. Commencez par le <a href={getLocaleUrl('docs/configuration', locale)}>guide de configuration</a>, qui exécute l'étape de nettoyage avant tout.
          </p>
        </Callout>
      </div>
    </div>
  </Reveal>

  <!-- Étape suivante -->
  <Reveal delay={160}>
    <div class="flex flex-col items-start gap-4 rounded-xl bg-stone-100 p-6 sm:flex-row sm:items-center sm:justify-between dark:bg-stone-800">
      <div>
        <h2 class="text-xl font-bold">Prêt à configurer ?</h2>
        <p class="text-stone-600 dark:text-stone-300">Donnez au boilerplate votre identité, vos langues et votre contenu.</p>
      </div>
      <a href={getLocaleUrl('docs/configuration', locale)} class="btn-primary group shrink-0">
        {t('pages.docs.title-configuration')}
        <Icon name="heroicons:arrow-right" class="mr-1 ml-0 h-4 w-4 transition-all duration-200 group-hover:mr-0 group-hover:ml-1" aria-hidden="true" />
      </a>
    </div>
  </Reveal>
</Layout>
