---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import { Code } from "astro-expressive-code/components";
import Callout from "@components/docs/callout.astro";
import Reveal from "@components/reveal.astro";
import Topic from "@components/docs/topic.astro";
import FieldList from "@components/docs/field-list.astro";
import Field from "@components/docs/field.astro";
import { useTranslations } from "@utils/i18n";

const locale = 'fr';
const t = useTranslations(locale);

// Le délimiteur du frontmatter YAML est construit via cette constante pour que les
// exemples de code ne contiennent jamais une ligne qui soit littéralement "---". Une telle
// ligne dans ces template literals serait sinon confondue avec le délimiteur de fermeture
// du frontmatter de ce composant Astro et casserait l'analyse.
const fence = "---";

const blogFrontmatter = `${fence}
title: "Comment WebMCP change la donne"
publishDate: 2026-01-15
excerpt: "Un court teaser pour les listes et les aperçus."
draft: false
featured: true
slug: "fr/webmcp-change-la-donne"
externalCanonical: "https://example.com/article-original"
image:
  file: "@images/content/articles/webmcp.jpg"   # locale, optimisée (recommandé)
  # url: "https://cdn.example.com/webmcp.jpg"  # alternative externe
  alt: "Illustration d'un agent IA utilisant des outils"
tags: ["ai", "webmcp"]
categories: ["engineering"]
${fence}

Le corps en Markdown va ici.`;

const faqFrontmatter = `${fence}
question: "Puis-je héberger Stardrive moi-même ?"
category: "general"
draft: false
${fence}

Absolument. Stardrive produit un site statique par défaut et fonctionne sur n'importe quel hébergeur.`;

const eventFrontmatter = `${fence}
title: "Webinaire en direct : construire pour l'ère de l'IA"
publishDate: 2026-02-01
startDate: 2026-02-20T17:00:00
endDate: 2026-02-20T18:00:00
timeZone: "Europe/Paris"
location: "En ligne"
description: "Rejoignez une session pratique avec notre équipe produit."
organizer:
  name: "Équipe Stardrive"
  email: "events@example.com"
# rrule: "FREQ=WEEKLY;BYDAY=WE"   # récurrence optionnelle
image:
  file: ./webinar.jpg
  alt: "Visuel du webinaire"
${fence}

Une description riche en Markdown de l'événement.`;

const integrationFrontmatter = `${fence}
type: "native"
service: "Google Sheets"
title: "Synchroniser des données vers Google Sheets"
description: "Envoyez des enregistrements dans une feuille de calcul en temps réel."
url: "https://example.com/integrations/google-sheets"
logo:
  file: "@images/content/integration-options/google-sheets.svg"
  alt: "Logo Google Sheets"
${fence}`;
---

<Layout title={t('pages.docs.title-guide')} description={t('pages.docs.description-guide')} {locale}>
  <Headline text={t('pages.docs.title-guide')} class="pb-6" />

  <p class="mb-10 max-w-2xl text-lg text-stone-600 dark:text-stone-300">Votre site est configuré et prêt - place au travail quotidien. Dépliez n'importe quel thème ci-dessous pour voir comment le contenu circule dans Stardrive et quelles options débloquent les fonctionnalités les plus puissantes.</p>

  <Reveal>
    <div class="flex flex-col gap-4">
      <!-- Blog -->
      <Topic icon="heroicons:newspaper" title="Rédiger des articles de blog" tagline="Des fichiers Markdown avec un frontmatter puissant">
        <p>
          Chaque article de blog est un fichier Markdown dans <code>./src/content/articles/</code> (organisé par langue). Le frontmatter débloque les fonctionnalités spéciales :
        </p>

        <FieldList class="my-4" title="Options du frontmatter">
          <Field name="title" type="string" badge="obligatoire" badgeTone="neutral">Le titre de l'article.</Field>
          <Field name="publishDate" type="date" badge="obligatoire" badgeTone="neutral">La date de publication, utilisée pour le tri et l'affichage.</Field>
          <Field name="updateDate" type="date">Une date optionnelle de « dernière mise à jour ».</Field>
          <Field name="excerpt" type="string">Un court teaser utilisé dans les listes et les aperçus.</Field>
          <Field name="draft" type="boolean" badge="spécial">Garde l'article hors des builds de production pendant que vous travaillez dessus.</Field>
          <Field name="featured" type="boolean" badge="spécial">Met l'article en avant partout où les articles à la une sont affichés.</Field>
          <Field name="llmsTxt" type="boolean" badge="spécial">Inclut l'article dans le <code>llms.txt</code> généré (lorsque <code>addArticles</code> vaut <code>selected</code> dans la configuration du thème).</Field>
          <Field name="externalCanonical" type="string" badge="SEO">Pointe l'URL canonique ailleurs - idéal pour le contenu republié.</Field>
          <Field name="slug" type="string">Un slug personnalisé plus propre. Incluez le code de langue, p. ex. <code>fr/mon-article</code>.</Field>
          <Field name="i18nSlug" type="object">Nécessaire uniquement quand le <strong>nom de fichier diffère selon la langue</strong>. Associez chaque langue à son slug, p. ex. <code>{`{ de: "de/mein-post", en: "en/my-post" }`}</code>.</Field>
          <Field name="image.file" type="chemin" badgeTone="secondary" badge="locale">Une image principale locale, optimisée au build. Référencez-la via l'alias <code>@images/…</code>, p. ex. <code>@images/content/articles/webmcp.jpg</code> (recommandé).</Field>
          <Field name="image.url" type="string" badgeTone="secondary" badge="externe">Une URL d'image principale externe comme alternative au fichier local.</Field>
          <Field name="image.alt" type="string">Texte alternatif pour l'image principale.</Field>
          <Field name="tags" type="string[]">Des tags pour le filtrage et le contenu associé.</Field>
          <Field name="categories" type="string[]">Les catégories auxquelles l'article appartient.</Field>
          <Field name="author" type="object">Auteur avec <code>name</code> et <code>url</code> optionnelle.</Field>
          <Field name="tocDepth" type="number">Combien de niveaux de titres la table des matières inclut.</Field>
        </FieldList>

        <Code code={blogFrontmatter} lang="md" title="src/content/articles/fr/webmcp-change-la-donne.md" />

        <Callout variant="tip" title="Faites des commits depuis n'importe où" class="mt-4">
          <p>Comme les articles ne sont que des fichiers, un autre système peut faire un commit de Markdown dans votre dépôt - chaque push déclenche un nouveau build.</p>
        </Callout>
        <Callout variant="note" title="Option CMS headless" class="mt-3">
          <p>Vous <em>pouvez</em> récupérer les articles dynamiquement depuis un CMS headless comme <a href="https://directus.io/" class="external-link" target="_blank" rel="noopener">Directus</a> ou <a href="https://strapi.io/" class="external-link" target="_blank" rel="noopener">Strapi</a>, mais cela demande des ajustements plus importants de la couche de contenu.</p>
        </Callout>
      </Topic>

      <!-- FAQ -->
      <Topic icon="heroicons:question-mark-circle" title="Ajouter des entrées de FAQ" tagline="Comme les articles de blog, mais plus courtes">
        <p>
          Les réponses de la FAQ vivent dans <code>./src/content/faq-answers/</code> sous forme de fichiers Markdown - la même idée que les articles de blog, mais avec un schéma léger. La <code>question</code> devient le titre et le corps Markdown est la réponse.
        </p>

        <FieldList class="my-4" title="Options du frontmatter">
          <Field name="question" type="string" badge="obligatoire" badgeTone="neutral">Le texte de la question affiché dans l'accordéon.</Field>
          <Field name="category" type="string">Regroupe l'entrée pour pouvoir la filtrer sur la page FAQ.</Field>
          <Field name="publishDate" type="date">Une date de publication optionnelle.</Field>
          <Field name="updateDate" type="date">Une date optionnelle de « dernière mise à jour ».</Field>
          <Field name="draft" type="boolean" badge="spécial">Masque l'entrée dans les builds de production.</Field>
          <Field name="llmsTxt" type="boolean" badge="spécial">Inclut l'entrée dans le <code>llms.txt</code> généré.</Field>
        </FieldList>

        <Code code={faqFrontmatter} lang="md" title="src/content/faq-answers/fr/self-hosting.md" />
      </Topic>

      <!-- Intégrations -->
      <Topic icon="heroicons:puzzle-piece" title="Ajouter des intégrations" tagline="Montrez comment votre produit se connecte à d'autres services">
        <h4>Quand l'utiliser</h4>
        <p>Utilisez la section intégrations lorsque votre produit peut être utilisé ou combiné avec d'autres services - pensez aux automatisations, à la synchronisation de données ou aux connecteurs natifs. Elle offre aux visiteurs un catalogue navigable.</p>

        <h4>Structure</h4>
        <p>
          Le contenu vit dans <code>./src/content/integration-options/</code>. Pensez <strong>catégorie d'abord, puis services</strong> : le champ <code>type</code>
          <strong>est la catégorie</strong> - il regroupe les entrées et pilote en même temps le routage (p. ex. <code>native</code>, <code>zapier</code>, <code>make</code>, <code>n8n</code>). Chaque service est ensuite son propre fichier Markdown au sein de cette catégorie.
        </p>

        <FieldList class="my-4" title="Options du frontmatter">
          <Field name="type" type="string" badge="obligatoire" badgeTone="neutral">La catégorie à laquelle le service appartient - aussi utilisée pour le routage, p. ex. <code>native</code>, <code>zapier</code>, <code>make</code>.</Field>
          <Field name="service" type="string" badge="obligatoire" badgeTone="neutral">Le nom du service, p. ex. <code>Google Sheets</code>.</Field>
          <Field name="title" type="string" badge="obligatoire" badgeTone="neutral">Le titre de l'intégration.</Field>
          <Field name="description" type="string">Une brève description de l'intégration.</Field>
          <Field name="url" type="string">Lien vers les détails ou la page de configuration de l'intégration.</Field>
          <Field name="publishDate" type="date">Une date de publication optionnelle.</Field>
          <Field name="updateDate" type="date">Une date optionnelle de « dernière mise à jour ».</Field>
          <Field name="draft" type="boolean" badge="spécial">Masque l'entrée dans les builds de production.</Field>
          <Field name="slug" type="string">Un slug personnalisé plus propre. Incluez le code de langue, p. ex. <code>fr/google-sheets</code>.</Field>
          <Field name="i18nSlug" type="object">Nécessaire uniquement quand le <strong>nom de fichier diffère selon la langue</strong>, p. ex. <code>{`{ de: "de/…", en: "en/…" }`}</code>.</Field>
          <Field name="logo.file" type="chemin">Le logo du service via l'alias <code>@images/…</code> (utilisez un SVG comme fichier compatible avec les composants).</Field>
          <Field name="logo.url" type="string">Une URL de logo externe comme alternative au fichier local.</Field>
          <Field name="logo.alt" type="string">Texte alternatif pour le logo.</Field>
        </FieldList>

        <Code code={integrationFrontmatter} lang="md" title="src/content/integration-options/fr/google-sheets.md" />

        <Callout variant="warning" title="Même service dans plusieurs catégories" class="mt-4">
          <p>
            Un service peut apparaître sous plus d'un <code>type</code> (catégorie) - créez simplement un fichier Markdown par catégorie. Dans ce cas, les fichiers <strong>doivent avoir des noms de fichier différents</strong>, sinon les entrées entrent en collision. Donnez à chacun un nom distinct (ou utilisez un nom de fichier haché plus un <code>slug</code> personnalisé).
          </p>
        </Callout>
      </Topic>

      <!-- Tarifs -->
      <Topic icon="heroicons:table-cells" title="Grilles tarifaires" tagline="Paliers flexibles, taxes et périodes de facturation">
        <Callout variant="note" title="Pas encore implémenté">
          <p>La grille tarifaire est sur la feuille de route. Cette section explique le modèle prévu pour que vous puissiez anticiper.</p>
        </Callout>
        <p class="mt-3">
          Vous pourrez définir des prix différents par palier - <strong>mensuel</strong>, <strong>annuel</strong> et
          <strong>à vie</strong> - et les afficher <strong>avec ou sans taxes</strong>. La présentation est entièrement configurable, c'est donc vous qui décidez de ce que voient les clients.
        </p>
        <div class="my-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border border-stone-300 p-4 text-center dark:border-stone-700">
            <p class="text-sm font-semibold text-stone-500 uppercase dark:text-stone-400">Mensuel</p>
          </div>
          <div class="border-primary rounded-lg border-2 p-4 text-center">
            <p class="text-primary text-sm font-semibold uppercase">Annuel</p>
          </div>
          <div class="rounded-lg border border-stone-300 p-4 text-center dark:border-stone-700">
            <p class="text-sm font-semibold text-stone-500 uppercase dark:text-stone-400">À vie</p>
          </div>
        </div>
        <Callout variant="recommend" title="Récupérer les tarifs dynamiquement">
          <p>
            Nous recommandons de récupérer ces données depuis un backend qui dialogue avec un fournisseur comme <a href="https://stripe.com/" class="external-link" target="_blank" rel="noopener">Stripe</a> ou <a href="https://www.paddle.com/" class="external-link" target="_blank" rel="noopener">Paddle</a>. Ainsi, les taxes peuvent être affichées dynamiquement selon la localisation du visiteur.
          </p>
        </Callout>
      </Topic>

      <!-- Événements -->
      <Topic icon="heroicons:calendar-days" title="Événements" tagline="Événements en Markdown, ou reflétés depuis Add to Calendar PRO">
        <p>
          Les événements fonctionnent comme les articles de blog : des fichiers Markdown dans <code>./src/content/events/</code>, prêts pour l'i18n, avec des boutons « Ajouter au calendrier » en un clic, des fuseaux horaires et des pages de détail riches.
        </p>

        <FieldList class="my-4" title="Options du frontmatter">
          <Field name="title" type="string" badge="obligatoire" badgeTone="neutral">Le titre de l'événement.</Field>
          <Field name="publishDate" type="date" badge="obligatoire" badgeTone="neutral">La date de publication, utilisée pour le tri et l'affichage.</Field>
          <Field name="startDate" type="date" badge="obligatoire" badgeTone="neutral">Quand l'événement commence.</Field>
          <Field name="endDate" type="date" badge="obligatoire" badgeTone="neutral">Quand l'événement se termine.</Field>
          <Field name="updateDate" type="date">Une date optionnelle de « dernière mise à jour ».</Field>
          <Field name="description" type="string">Brève description pour l'événement partageable (utilisez le corps Markdown pour plus de détail).</Field>
          <Field name="allDay" type="boolean">Marque l'événement comme durant toute la journée.</Field>
          <Field name="timeZone" type="string">Un fuseau horaire IANA valide, p. ex. <code>Europe/Paris</code>.</Field>
          <Field name="location" type="string">Où l'événement a lieu.</Field>
          <Field name="organizer" type="object">Organisateur avec <code>name</code> et <code>email</code>.</Field>
          <Field name="rrule" type="string">Une règle de récurrence, p. ex. <code>FREQ=WEEKLY;BYDAY=MO,WE,FR</code>.</Field>
          <Field name="icsFile" type="string">Pointez vers un fichier <code>.ics</code> statique au lieu d'en générer un dynamiquement.</Field>
          <Field name="slug" type="string">Un slug personnalisé plus propre. Incluez le code de langue, p. ex. <code>fr/mon-evenement</code>.</Field>
          <Field name="i18nSlug" type="object">Nécessaire uniquement quand le <strong>nom de fichier diffère selon la langue</strong>, p. ex. <code>{`{ de: "de/…", en: "en/…" }`}</code>.</Field>
          <Field name="draft" type="boolean" badge="spécial">Garde l'événement hors des builds de production pendant que vous travaillez dessus.</Field>
          <Field name="llmsTxt" type="boolean" badge="spécial">Inclut l'événement dans le <code>llms.txt</code> généré.</Field>
          <Field name="image.file" type="chemin" badgeTone="secondary" badge="locale">Une image locale, optimisée au build, via l'alias <code>@images/…</code>.</Field>
          <Field name="image.url" type="string" badgeTone="secondary" badge="externe">Une URL d'image externe comme alternative au fichier local.</Field>
          <Field name="image.alt" type="string">Texte alternatif pour l'image.</Field>
        </FieldList>

        <Code code={eventFrontmatter} lang="md" title="src/content/events/fr/ai-webinar.md" />

        <Callout variant="recommend" title="Reflétez depuis Add to Calendar PRO" class="mt-4">
          <p>
            Alternativement, connectez <a href="https://add-to-calendar-pro.com/" class="external-link" target="_blank" rel="noopener">Add to Calendar PRO</a>
            avec un filtre sur un groupe d'événements précis. Les événements sont alors reflétés dynamiquement dans la page - l'équipe marketing peut effectuer des changements dans l'application web <strong>sans aucun redéploiement</strong>.
          </p>
          <p>Parfait pour les webinaires, les événements d'entreprise et les calendriers de relations investisseurs.</p>
        </Callout>
      </Topic>
    </div>
  </Reveal>
</Layout>
