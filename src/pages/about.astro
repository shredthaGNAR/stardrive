---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import AboutContent from "@components/about/about-content.astro";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

const locale = themeConfig.i18n.defaultLocale;
const t = useTranslations(locale);

// Years spent building for the web, counted from 2003 to the current year.
const yearsBuilding = new Date().getFullYear() - 2003;

const content = {
  imageAlt: "The team behind Astro Stardrive",
  lead: "Hi, I'm Jens. I've been building websites since the year 2000 - from super simple HTML back then, through PHP and WordPress, all the way to modern frameworks like React, Angular and Vue. Stardrive is where all of that experience comes together.",
  stats: [
    { icon: "heroicons:calendar-days", value: `${yearsBuilding}+ years`, label: "building for the web" },
    { icon: "heroicons:code-bracket-square", value: "HTML → Astro", label: "the full journey" },
    { icon: "heroicons:magnifying-glass", value: "SEO & marketing", label: "baked right in" },
    { icon: "heroicons:lock-open", value: "Open source", label: "MIT licensed" },
  ],
  storyHeading: "The journey",
  timeline: [
    {
      year: "2003",
      title: "It started with plain HTML",
      text: "Hand-written pages, a text editor and a lot of curiosity. The web was simple - and that simplicity taught me the fundamentals.",
    },
    {
      year: "The PHP & WordPress years",
      title: "Dynamic sites at scale",
      text: "Server-rendered pages, content management and everything WordPress could throw at a project. Powerful, but heavy to maintain.",
    },
    {
      year: "Modern frameworks",
      title: "React, Angular & Vue",
      text: "The component era. Rich interactivity, but often at the cost of performance, complexity and long-term maintenance.",
    },
    {
      year: "Today",
      title: "Astro brings it together",
      text: "In my opinion Astro extends the latest developments into something that simply delivers the best performance at the lowest cost with minimal maintenance - while respecting the root of it all: native web technology. Getting back to working basics instead of overcomplicating things, then bringing those basics into the modern world. That's a trend among real industry pros, and Astro combines all of it.",
    },
  ],
  highlightsHeading: "Why Stardrive exists",
  highlights: [
    {
      icon: "heroicons:rocket-launch",
      title: "Speed up development",
      text: "I built Stardrive to skip the first 36 steps of every project - a strong foundation you can start building on right away.",
    },
    {
      icon: "heroicons:wrench-screwdriver",
      title: "Features & utilities included",
      text: "A lot of small utilities and features that make Astro projects even better from the very first commit.",
    },
    {
      icon: "heroicons:chart-bar",
      title: "Marketing & SEO expertise",
      text: "Beyond engineering I studied marketing and worked in the SEO industry for years - that knowledge is woven into this project.",
    },
    {
      icon: "heroicons:shield-check",
      title: "Best practices by default",
      text: "Security, accessibility, structured data and performance are there from the start, so you don't have to bolt them on later.",
    },
  ],
  openSourceHeading: "Built in the open",
  openSourceText: "Stardrive is open source because I believe in the power of having things out in the open - getting feedback, watching them grow, and finding contributors along the way. If it helps you ship a better website faster, that's exactly the point.",
  authorCtaLabel: "More about Jens",
};
---

<Layout title={t('pages.about.title')} description={t('pages.about.description')}>
  <Headline text={t('pages.about.title')} class="pb-10" />
  <AboutContent {...content} />
</Layout>
