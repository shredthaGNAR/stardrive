---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import { Code } from "astro-expressive-code/components";
import Callout from "@components/docs/callout.astro";
import Reveal from "@components/reveal.astro";
import Topic from "@components/docs/topic.astro";
import FieldList from "@components/docs/field-list.astro";
import Field from "@components/docs/field.astro";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

const locale = themeConfig.i18n.defaultLocale;
const t = useTranslations(locale);

// The YAML frontmatter fence is built via this constant so the code samples never
// contain a line that is literally "---". A bare "---" line inside these template
// literals would otherwise be mistaken for the closing fence of this Astro component's
// own frontmatter and break parsing.
const fence = "---";

const blogFrontmatter = `${fence}
title: "How WebMCP changes the game"
publishDate: 2026-01-15
excerpt: "A short teaser for lists and previews."
draft: false
featured: true
slug: "en/webmcp-changes-the-game"
externalCanonical: "https://example.com/original-post"
image:
  file: "@images/content/articles/webmcp.jpg"   # local, optimized (recommended)
  # url: "https://cdn.example.com/webmcp.jpg"  # external alternative
  alt: "Illustration of an AI agent using tools"
tags: ["ai", "webmcp"]
categories: ["engineering"]
${fence}

Your Markdown body goes here.`;

const faqFrontmatter = `${fence}
question: "Can I self-host Stardrive?"
category: "general"
draft: false
${fence}

Absolutely. Stardrive outputs a static site by default and runs on any host.`;

const eventFrontmatter = `${fence}
title: "Live webinar: Building for the AI age"
publishDate: 2026-02-01
startDate: 2026-02-20T17:00:00
endDate: 2026-02-20T18:00:00
timeZone: "Europe/Berlin"
location: "Online"
description: "Join our product team for a hands-on session."
organizer:
  name: "Stardrive Team"
  email: "events@example.com"
# rrule: "FREQ=WEEKLY;BYDAY=WE"   # optional recurrence
image:
  file: ./webinar.jpg
  alt: "Webinar cover"
${fence}

A rich, Markdown description of the event.`;

const integrationFrontmatter = `${fence}
type: "native"
service: "Google Sheets"
title: "Sync data to Google Sheets"
description: "Push records into a spreadsheet in real time."
url: "https://example.com/integrations/google-sheets"
logo:
  file: "@images/content/integration-options/google-sheets.svg"
  alt: "Google Sheets logo"
${fence}`;
---

<Layout title={t('pages.docs.title-guide')} description={t('pages.docs.description-guide')}>
  <Headline text={t('pages.docs.title-guide')} class="pb-6" />

  <p class="mb-10 max-w-2xl text-lg text-stone-600 dark:text-stone-300">Your site is configured and ready - now for the everyday work. Expand any topic below to see how content flows through Stardrive and which options unlock the more powerful features.</p>

  <Reveal>
    <div class="flex flex-col gap-4">
      <!-- Blog -->
      <Topic icon="heroicons:newspaper" title="Writing blog posts" tagline="Markdown files with a powerful frontmatter">
        <p>
          Each blog post is a Markdown file in <code>./src/content/articles/</code> (organised per language). The frontmatter unlocks the special functionality:
        </p>

        <FieldList class="my-4" title="Frontmatter options">
          <Field name="title" type="string" badge="required" badgeTone="neutral">The article title.</Field>
          <Field name="publishDate" type="date" badge="required" badgeTone="neutral">The publication date, used for ordering and display.</Field>
          <Field name="updateDate" type="date">An optional "last updated" date.</Field>
          <Field name="excerpt" type="string">A short teaser used in lists and previews.</Field>
          <Field name="draft" type="boolean" badge="special">Keeps the post out of production builds while you work on it.</Field>
          <Field name="featured" type="boolean" badge="special">Highlights the post wherever featured articles are surfaced.</Field>
          <Field name="llmsTxt" type="boolean" badge="special">Includes the post in the generated <code>llms.txt</code> (when <code>addArticles</code> is set to <code>selected</code> in the theme config).</Field>
          <Field name="externalCanonical" type="string" badge="SEO">Points the canonical URL elsewhere - ideal for cross-posted content.</Field>
          <Field name="slug" type="string">A cleaner custom slug. Include the language code, e.g. <code>en/my-post</code>.</Field>
          <Field name="i18nSlug" type="object">Only needed when the <strong>filename differs per language</strong>. Map each locale to its slug, e.g. <code>{`{ de: "de/mein-post", en: "en/my-post" }`}</code>.</Field>
          <Field name="image.file" type="path" badgeTone="secondary" badge="local">A local, build-optimized hero image. Reference it via the <code>@images/…</code> alias, e.g. <code>@images/content/articles/webmcp.jpg</code> (recommended).</Field>
          <Field name="image.url" type="string" badgeTone="secondary" badge="external">An external hero image URL as an alternative to a local file.</Field>
          <Field name="image.alt" type="string">Alt text for the hero image.</Field>
          <Field name="tags" type="string[]">Tags for filtering and related content.</Field>
          <Field name="categories" type="string[]">Categories the article belongs to.</Field>
          <Field name="author" type="object">Author <code>name</code> and optional <code>url</code>.</Field>
          <Field name="tocDepth" type="number">How many heading levels the table of contents includes.</Field>
        </FieldList>

        <Code code={blogFrontmatter} lang="md" title="src/content/articles/en/webmcp-changes-the-game.md" />

        <Callout variant="tip" title="Commit from anywhere" class="mt-4">
          <p>Because posts are just files, another system can commit Markdown into your repository - every push triggers a fresh build.</p>
        </Callout>
        <Callout variant="note" title="Headless CMS option" class="mt-3">
          <p>You <em>can</em> pull posts dynamically from a headless CMS like <a href="https://directus.io/" class="external-link" target="_blank" rel="noopener">Directus</a> or <a href="https://strapi.io/" class="external-link" target="_blank" rel="noopener">Strapi</a>, but that requires bigger adjustments to the content layer.</p>
        </Callout>
      </Topic>

      <!-- FAQ -->
      <Topic icon="heroicons:question-mark-circle" title="Adding FAQ entries" tagline="Just like blog posts, only shorter">
        <p>
          FAQ answers live in <code>./src/content/faq-answers/</code> as Markdown files - the same idea as blog posts, but with a lightweight schema. The <code>question</code> becomes the headline and the Markdown body is the answer.
        </p>

        <FieldList class="my-4" title="Frontmatter options">
          <Field name="question" type="string" badge="required" badgeTone="neutral">The question text shown in the accordion.</Field>
          <Field name="category" type="string">Groups the entry so it can be filtered on the FAQ page.</Field>
          <Field name="publishDate" type="date">An optional publication date.</Field>
          <Field name="updateDate" type="date">An optional "last updated" date.</Field>
          <Field name="draft" type="boolean" badge="special">Hides the entry from production builds.</Field>
          <Field name="llmsTxt" type="boolean" badge="special">Includes the entry in the generated <code>llms.txt</code>.</Field>
        </FieldList>

        <Code code={faqFrontmatter} lang="md" title="src/content/faq-answers/en/self-hosting.md" />
      </Topic>

      <!-- Integrations -->
      <Topic icon="heroicons:puzzle-piece" title="Adding integrations" tagline="Show how your product connects to other services">
        <h4>When to use it</h4>
        <p>Use the integrations section when your product can be used or combined with other services - think automations, data sync, or native connectors. It gives visitors a browsable catalogue.</p>

        <h4>Structure</h4>
        <p>
          Content lives in <code>./src/content/integration-options/</code>. Think <strong>category first, then services</strong>: the <code>type</code> field <strong>is the category</strong> - it both groups the entries and drives the routing (e.g. <code>native</code>, <code>zapier</code>, <code>make</code>, <code>n8n</code>). Each service is then its own Markdown file inside that category.
        </p>

        <FieldList class="my-4" title="Frontmatter options">
          <Field name="type" type="string" badge="required" badgeTone="neutral">The category the service belongs to - also used for routing, e.g. <code>native</code>, <code>zapier</code>, <code>make</code>.</Field>
          <Field name="service" type="string" badge="required" badgeTone="neutral">The service name, e.g. <code>Google Sheets</code>.</Field>
          <Field name="title" type="string" badge="required" badgeTone="neutral">The integration title.</Field>
          <Field name="description" type="string">A short description of the integration.</Field>
          <Field name="url" type="string">Link to the integration details or setup page.</Field>
          <Field name="publishDate" type="date">An optional publication date.</Field>
          <Field name="updateDate" type="date">An optional "last updated" date.</Field>
          <Field name="draft" type="boolean" badge="special">Hides the entry from production builds.</Field>
          <Field name="slug" type="string">A cleaner custom slug. Include the language code, e.g. <code>en/google-sheets</code>.</Field>
          <Field name="i18nSlug" type="object">Only needed when the <strong>filename differs per language</strong>, e.g. <code>{`{ de: "de/…", en: "en/…" }`}</code>.</Field>
          <Field name="logo.file" type="path">The service logo via the <code>@images/…</code> alias (use an SVG as a component-friendly file).</Field>
          <Field name="logo.url" type="string">An external logo URL as an alternative to a local file.</Field>
          <Field name="logo.alt" type="string">Alt text for the logo.</Field>
        </FieldList>

        <Code code={integrationFrontmatter} lang="md" title="src/content/integration-options/en/google-sheets.md" />

        <Callout variant="warning" title="Same service in multiple categories" class="mt-4">
          <p>
            A service can appear under more than one <code>type</code> (category) - just create one Markdown file per category. In that case the files <strong>must have different filenames</strong>, otherwise the entries collide. Give each a distinct name (or use a hashed filename plus a custom <code>slug</code>).
          </p>
        </Callout>
      </Topic>

      <!-- Pricing -->
      <Topic icon="heroicons:table-cells" title="Pricing tables" tagline="Flexible tiers, taxes and billing periods">
        <Callout variant="note" title="Not wired up yet">
          <p>The pricing table is on the roadmap. This section explains the intended model so you can plan ahead.</p>
        </Callout>
        <p class="mt-3">
          You will be able to define different prices per tier - <strong>monthly</strong>, <strong>annually</strong> and
          <strong>lifetime</strong> - and show them <strong>with or without taxes</strong>. The presentation is fully configurable, so you decide what customers see.
        </p>
        <div class="my-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border border-stone-300 p-4 text-center dark:border-stone-700">
            <p class="text-sm font-semibold text-stone-500 uppercase dark:text-stone-400">Monthly</p>
          </div>
          <div class="border-primary rounded-lg border-2 p-4 text-center">
            <p class="text-primary text-sm font-semibold uppercase">Annually</p>
          </div>
          <div class="rounded-lg border border-stone-300 p-4 text-center dark:border-stone-700">
            <p class="text-sm font-semibold text-stone-500 uppercase dark:text-stone-400">Lifetime</p>
          </div>
        </div>
        <Callout variant="recommend" title="Pull pricing dynamically">
          <p>
            We recommend sourcing this data from a backend that talks to a provider like <a href="https://stripe.com/" class="external-link" target="_blank" rel="noopener">Stripe</a> or <a href="https://www.paddle.com/" class="external-link" target="_blank" rel="noopener">Paddle</a>. That way taxes can be shown dynamically based on the visitor's location.
          </p>
        </Callout>
      </Topic>

      <!-- Events -->
      <Topic icon="heroicons:calendar-days" title="Events" tagline="Markdown events, or mirror them from Add to Calendar PRO">
        <p>
          Events work like blog posts: Markdown files in <code>./src/content/events/</code>, i18n-ready, with one-click "Add to Calendar" buttons, time zones and rich detail pages.
        </p>

        <FieldList class="my-4" title="Frontmatter options">
          <Field name="title" type="string" badge="required" badgeTone="neutral">The event title.</Field>
          <Field name="publishDate" type="date" badge="required" badgeTone="neutral">The publication date, used for ordering and display.</Field>
          <Field name="startDate" type="date" badge="required" badgeTone="neutral">When the event begins.</Field>
          <Field name="endDate" type="date" badge="required" badgeTone="neutral">When the event ends.</Field>
          <Field name="updateDate" type="date">An optional "last updated" date.</Field>
          <Field name="description" type="string">Short description used for the shareable event (use the Markdown body for richer detail).</Field>
          <Field name="allDay" type="boolean">Marks the event as all-day.</Field>
          <Field name="timeZone" type="string">A valid IANA time zone, e.g. <code>Europe/Berlin</code>.</Field>
          <Field name="location" type="string">Where the event takes place.</Field>
          <Field name="organizer" type="object">Organizer <code>name</code> and <code>email</code>.</Field>
          <Field name="rrule" type="string">A recurrence rule, e.g. <code>FREQ=WEEKLY;BYDAY=MO,WE,FR</code>.</Field>
          <Field name="icsFile" type="string">Point to a static <code>.ics</code> file instead of generating one dynamically.</Field>
          <Field name="slug" type="string">A cleaner custom slug. Include the language code, e.g. <code>en/my-event</code>.</Field>
          <Field name="i18nSlug" type="object">Only needed when the <strong>filename differs per language</strong>, e.g. <code>{`{ de: "de/…", en: "en/…" }`}</code>.</Field>
          <Field name="draft" type="boolean" badge="special">Keeps the event out of production builds while you work on it.</Field>
          <Field name="llmsTxt" type="boolean" badge="special">Includes the event in the generated <code>llms.txt</code>.</Field>
          <Field name="image.file" type="path" badgeTone="secondary" badge="local">A local, build-optimized image via the <code>@images/…</code> alias.</Field>
          <Field name="image.url" type="string" badgeTone="secondary" badge="external">An external image URL as an alternative to a local file.</Field>
          <Field name="image.alt" type="string">Alt text for the image.</Field>
        </FieldList>

        <Code code={eventFrontmatter} lang="md" title="src/content/events/en/ai-webinar.md" />

        <Callout variant="recommend" title="Mirror from Add to Calendar PRO" class="mt-4">
          <p>
            Alternatively, connect <a href="https://add-to-calendar-pro.com/" class="external-link" target="_blank" rel="noopener">Add to Calendar PRO</a>
            with a filter on a specific event group. Events are then mirrored into the page dynamically - marketing can make changes in the web app with <strong>no re-deployment needed</strong>.
          </p>
          <p>Great for webinars, corporate events, and investor-relations calendars.</p>
        </Callout>
      </Topic>
    </div>
  </Reveal>
</Layout>
