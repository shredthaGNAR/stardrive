---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import { Icon } from "astro-icon/components";
import { Code } from "astro-expressive-code/components";
import Callout from "@components/docs/callout.astro";
import Reveal from "@components/reveal.astro";
import Steps from "@components/docs/steps.astro";
import Step from "@components/docs/step.astro";
import { useTranslations, getLocaleUrl } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

const locale = themeConfig.i18n.defaultLocale;
const t = useTranslations(locale);
---

<Layout title={t('pages.docs.title-configuration')} description={t('pages.docs.description-configuration')}>
  <Headline text={t('pages.docs.title-configuration')} class="pb-6" />

  <p class="mb-10 max-w-2xl text-lg text-stone-600 dark:text-stone-300">
    Configuration happens on a few levels: the central <code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-[0.9em] dark:bg-white/10">theme.config.ts</code>, the codebase itself, and a handful of build-time environment variables. Work through the steps below from top to bottom - each one builds on the previous.
  </p>

  <Reveal class="mb-12">
    <Callout variant="warning" title="Astro is a frontend framework">
      <p>Everything here runs on the client (static output, with optional on-demand rendering). Never store secrets or backend logic in this project - sensitive work belongs in a real backend service.</p>
    </Callout>
  </Reveal>

  <!-- Configuration levels overview -->
  <Reveal class="mb-14">
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="rounded-lg border border-stone-300 bg-white p-5 dark:border-stone-700 dark:bg-stone-900">
        <Icon name="heroicons:adjustments-horizontal" class="text-primary mb-3 h-7 w-7" aria-hidden="true" />
        <h3 class="mb-1 font-bold">1. theme.config.ts</h3>
        <p class="text-sm text-stone-600 dark:text-stone-300">Branding, i18n, blog, promo and llms.txt - all fully typed.</p>
      </div>
      <div class="rounded-lg border border-stone-300 bg-white p-5 dark:border-stone-700 dark:bg-stone-900">
        <Icon name="heroicons:code-bracket-square" class="text-primary mb-3 h-7 w-7" aria-hidden="true" />
        <h3 class="mb-1 font-bold">2. The codebase</h3>
        <p class="text-sm text-stone-600 dark:text-stone-300">This is a real Astro project - you still build the actual website.</p>
      </div>
      <div class="rounded-lg border border-stone-300 bg-white p-5 dark:border-stone-700 dark:bg-stone-900">
        <Icon name="heroicons:variable" class="text-primary mb-3 h-7 w-7" aria-hidden="true" />
        <h3 class="mb-1 font-bold">3. Env variables</h3>
        <p class="text-sm text-stone-600 dark:text-stone-300">A few build-time overrides like <code>SITE_OVERRIDE</code> and <code>ROBOTS</code>.</p>
      </div>
    </div>
  </Reveal>

  <h2 class="mb-8 text-2xl font-bold">Step-by-step</h2>

  <Steps class="mb-14">
    <Step number={1} title="Trim what you do not need">
      <p>
        If you did <strong>not</strong> use the <code>create stardrive</code> command, first remove the demo- and repo-only files. The <a href="https://github.com/Peltmonger/stardrive/blob/main/.ai/TRIMMING_GUIDE.md" class="external-link" target="_blank" rel="noopener">Trimming Guide</a> is written for AI agents but works fine for manual cleanup too.
      </p>
    </Step>

    <Step number={2} title="Make the project yours">
      <p>Adjust the basics so you recognise the project later:</p>
      <ul>
        <li>Update <code>package.json</code> to reflect your project.</li>
        <li>Set at least the headline in <code>README.md</code>.</li>
      </ul>
    </Step>

    <Step number={3} title="Replace favicons & social images">
      <p>
        Swap the icon files in <code>./public/</code> (we like <a href="https://realfavicongenerator.net/" class="external-link" target="_blank" rel="noopener">realfavicongenerator.net</a>). The web manifest is generated from <code>theme.config.ts</code>, so you only replace image files. Also replace the social fallbacks <code>og.png</code>, <code>x.png</code> and <code
          >structured-preview.png</code
        > in <code>./public/images/</code>.
      </p>
      <Callout variant="note" title="Light & dark favicons">
        <p>Stardrive ships separate light/dark icons. If you do not need that, drop the dark variants and adjust <code>./src/components/head/base.astro</code>. For the SVG, handle light/dark directly inside the SVG code.</p>
      </Callout>
    </Step>

    <Step number={4} title="Configure theme.config.ts">
      <p>This is the heart of the setup. Everything is typed, so your IDE surfaces the docs inline. Work through it in this order:</p>
      <ul>
        <li>Set the base info (site URL, primary color, …).</li>
        <li>Decide your languages, add a JSON file per language in <code>./src/i18n/</code>, and wire up the <code>i18n</code> block.</li>
        <li>Pick your <code>expressiveCodeThemes</code> - one for light, one for dark mode.</li>
        <li>Configure blog article defaults (and replace the fallback image if you use it).</li>
        <li>Set or disable promotion slots.</li>
        <li>Define how <code>llms.txt</code> is generated.</li>
      </ul>
    </Step>

    <Step number={5} title="Fonts & Tailwind base">
      <p>
        Stardrive ships with <em>Geist</em> via Fontsource. Swap it for your own (<code>npm un @fontsource/geist</code>, then install yours). Adjust the import statements at the layout files. Then adjust
        <code>./src/styles/tailwind.config.css</code>:
      </p>
      <ul>
        <li>Update the font section.</li>
        <li>Adjust the branding colors (change hex codes; only remove lines once the demo content is gone).</li>
        <li>Tweak breakpoints if you like.</li>
      </ul>
    </Step>

    <Step number={6} title="Layer in your styles">
      <p>Extend the CSS files in <code>./src/styles/</code> following the layering convention:</p>
      <ul>
        <li>Tailwind as the base.</li>
        <li><code>global.css</code> for custom rules and single-source-of-truth styles (e.g. buttons).</li>
        <li>Page-specific CSS files (e.g. <code>long-text-content.css</code>) imported per page.</li>
        <li>Very custom bits stay scoped in the page or component.</li>
      </ul>
    </Step>

    <Step number={7} title="Prune unused languages">
      <p>
        Delete the subfolders in <code>./src/content/</code> and <code>./src/pages/</code> for languages you do not support. Running a single language? You can also drop <code>./src/pages/[lang]</code> plus the language switcher components.
      </p>
    </Step>

    <Step number={8} title="Build your pages & navigation">
      <p>
        Shape your structure under <code>./src/pages/</code> (one file per route). Pages that differ only by translated strings go into <code>[lang]</code>; pages with large or differing text get an explicit language subfolder with hard-coded content. Then adjust the navigation in <code>./src/components/layout/nav/</code> and the other layout files.
      </p>
      <Callout variant="tip" title="Content translations">
        <p>While building the layout, keep the JSON files in <code>./src/i18n/</code> in sync with your project.</p>
      </Callout>
    </Step>

    <Step number={9} title="Swap the demo content">
      <p>
        Replace the demo images in <code>./src/images</code> (keep the folder structure!), update or remove the
        <code>./public/map/office.pmtiles</code> used on the demo contact page, and check the Open Graph / X meta in
        <code>./src/components/head/ogx.astro</code>.
      </p>
      <p>Then validate everything:</p>
      <Code code="npm run check:astro" lang="sh" title="Catch broken links after trimming" />
    </Step>

    <Step number={10} title="Prepare for deployment">
      <p>
        On Cloudflare, adjust <code>_headers</code> and <code>_redirects</code> in <code>./public/</code> and the
        <code>wrangler.jsonc</code>, then link your repository to a Worker. For migrations, map old paths in <code>_redirects</code>. Not on Cloudflare? Configure your host accordingly.
      </p>
      <Callout variant="recommend" title="Cache purging on Cloudflare">
        <p>
          Set <code>CF_PURGE_API_KEY</code> and <code>CF_PURGE_ZONE_ID</code> and run <code>npm run purge:cloudflare</code>
          after each build. Also enable Media &rarr; Images &rarr; Transformations in your Cloudflare dashboard.
        </p>
      </Callout>
    </Step>
  </Steps>

  <!-- Env variables -->
  <Reveal class="mb-14">
    <h2 class="mb-4 text-2xl font-bold">Build-time environment variables</h2>
    <div class="overflow-hidden rounded-lg border border-stone-300 bg-white dark:border-stone-700 dark:bg-stone-900">
      <dl class="m-0 divide-y divide-stone-200 dark:divide-stone-800">
        <div class="grid gap-1 px-4 py-3 sm:grid-cols-[minmax(0,18rem)_1fr] sm:gap-4">
          <dt><code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-sm font-semibold dark:bg-white/10">SITE_OVERRIDE</code></dt>
          <dd class="m-0 text-sm text-stone-700 dark:text-stone-300">Overrides the global site URL. Handy for dev environments.</dd>
        </div>
        <div class="grid gap-1 px-4 py-3 sm:grid-cols-[minmax(0,18rem)_1fr] sm:gap-4">
          <dt><code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-sm font-semibold dark:bg-white/10">ROBOTS</code></dt>
          <dd class="m-0 text-sm text-stone-700 dark:text-stone-300">Overrides the default robots setting. Page-level settings still win.</dd>
        </div>
        <div class="grid gap-1 px-4 py-3 sm:grid-cols-[minmax(0,18rem)_1fr] sm:gap-4">
          <dt><code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-sm font-semibold dark:bg-white/10">CF_PURGE_API_KEY</code><br /><code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-sm font-semibold dark:bg-white/10">CF_PURGE_ZONE_ID</code></dt>
          <dd class="m-0 text-sm text-stone-700 dark:text-stone-300">Required for the Cloudflare cache purge script.</dd>
        </div>
        <div class="grid gap-1 px-4 py-3 sm:grid-cols-[minmax(0,18rem)_1fr] sm:gap-4">
          <dt><code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-sm font-semibold dark:bg-white/10">ADD_TO_CALENDAR_PRO_API_KEY</code></dt>
          <dd class="m-0 text-sm text-stone-700 dark:text-stone-300">Enables the pre-built adapter for dynamically infused events.</dd>
        </div>
      </dl>
    </div>
  </Reveal>

  <!-- Next step -->
  <Reveal>
    <div class="flex flex-col items-start gap-4 rounded-xl bg-stone-100 p-6 sm:flex-row sm:items-center sm:justify-between dark:bg-stone-800">
      <div>
        <h2 class="text-xl font-bold">Site running? Time for content.</h2>
        <p class="text-stone-600 dark:text-stone-300">Learn the everyday workflows: blog, FAQ, integrations, pricing and events.</p>
      </div>
      <a href={getLocaleUrl('docs/guide', locale)} class="btn-primary group shrink-0">
        {t('pages.docs.title-guide')}
        <Icon name="heroicons:arrow-right" class="mr-1 ml-0 h-4 w-4 transition-all duration-200 group-hover:mr-0 group-hover:ml-1" aria-hidden="true" />
      </a>
    </div>
  </Reveal>
</Layout>
