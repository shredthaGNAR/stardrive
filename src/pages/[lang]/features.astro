---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import FeaturesList from "@components/features/features-list.astro";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

export function getStaticPaths() {
  return themeConfig.i18n.locales
    .filter(lang => lang !== themeConfig.i18n.defaultLocale)
    .map(lang => ({
      params: { lang: lang }
    }));
}

const locale = Astro.params.lang;
const t = useTranslations(locale);
---

<Layout title={t('pages.features.title')} description={t('pages.features.description')} {locale}>
  <Headline text={t('pages.features.title')} class="pb-10" />
  <p class="mb-10 max-w-2xl text-lg text-stone-600 dark:text-stone-300">{t('pages.features.description')}</p>
  <FeaturesList {locale} />
</Layout>
