---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import ExamplesList from "@components/examples/examples-list.astro";
import { Icon } from "astro-icon/components";
import { useTranslations, getLocaleUrl } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

export function getStaticPaths() {
  return themeConfig.i18n.locales
    .filter(lang => lang !== themeConfig.i18n.defaultLocale)
    .map(lang => ({
      params: { lang: lang }
    }));
}

const locale = Astro.params.lang;
const t = useTranslations(locale);
---

<Layout title={t('pages.examples.title')} description={t('pages.examples.description')} {locale}>
  <Headline text={t('pages.examples.title')} class="pb-6" />

  <div class="mb-12 flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
    <p class="max-w-2xl text-lg text-stone-600 dark:text-stone-300">{t('pages.examples.intro')}</p>
    <a href={getLocaleUrl('get-listed', locale)} class="btn-primary shrink-0">
      <Icon name="heroicons:plus-circle" class="h-5 w-5" aria-hidden="true" />
      {t('pages.examples.cta')}
    </a>
  </div>

  <ExamplesList emptyText={t('pages.examples.empty')} listLabel={t('pages.examples.list-label')} />
</Layout>
