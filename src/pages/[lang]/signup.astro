---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import SignupContent from "@components/signup-content.astro";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

export function getStaticPaths() {
  return themeConfig.i18n.locales
    .filter(lang => lang !== themeConfig.i18n.defaultLocale)
    .map(lang => ({
      params: { lang: lang }
    }));
}

const locale = Astro.params.lang;
const t = useTranslations(locale);
---

<Layout title={t('pages.signup.title')} description={t('pages.signup.description')} {locale}>
  <Headline text={t('pages.signup.title')} class="pb-10" />
  <SignupContent {locale} />
</Layout>
