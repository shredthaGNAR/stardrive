---
import Layout from "@layouts/default.astro";
import { Icon } from "astro-icon/components";
import Headline from "@components/headline.astro";
import AddToCalendarButton from "@components/add-to-calendar-button.astro";
import "@styles/events.css";
import { render } from 'astro:content';
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from 'astro';
import { themeConfig } from '~/theme.config';
import { Image } from 'astro:assets';
import { useTranslations, getLocaleUrl } from "@utils/i18n";
import { formatRange } from "@utils/helpers";
import { getEvents, getEventEntry } from "@utils/event-bridge";

export async function getStaticPaths() {
  const entries = await getEvents(({ id, data }) => {
    // only show events that are not drafts and not in the default locale (handled by the pages on root level)
    return !data.draft && !id.startsWith(themeConfig.i18n.defaultLocale + '/');
  }) as CollectionEntry<'events'>[];
  const paths = entries.map((entry: CollectionEntry<'events'>) => {
    const [lang, ...slug] = entry.id.split('/');
    return { params: { lang, event: slug.join('/') || undefined } };
  });
  return paths;
}

const locale = Astro.params.lang;
const t = useTranslations(locale);
const entry = await getEventEntry(locale + '/' + Astro.params.event as string);

// when rendered on demand (prerender = false), an unknown slug has no entry, so fall back to the 404 page. This is a no-op when prerendered, as getStaticPaths only generates valid paths.
if (!entry) return Astro.rewrite('/404_dynamic');

// get content: markdown events render their body, API events carry pre-rendered HTML
const Content = entry.dynamic ? null : (await render(entry as CollectionEntry<'events'>)).Content;
const bodyHtml = entry.dynamic ? entry.bodyHtml ?? '' : '';

// define image
const imageFile: ImageMetadata | undefined = entry.data.image?.file ? entry.data.image.file : undefined;

// define "back" url (to include year of event)
const backUrl = entry.data.startDate ? getLocaleUrl('events/' + new Date(entry.data.startDate).getFullYear(), locale) : getLocaleUrl('events', locale);

// date splited by -
const dateParts = formatRange(entry.data.startDate, entry.data.endDate, entry.data.allDay, locale).split(' - ');
---

<Layout title={entry.data.title} description={entry.data.description} {locale} collection="events" contentId={entry.id} header={{ button: { text: t('labels.back-all-events'), href: backUrl } }} noTitleSlug>
  <div class="flex flex-col">
    {
      imageFile ? (
        <Image src={imageFile} alt={entry.data.image?.alt ? entry.data.image?.alt : ''} id="title-image" transition:name={'image-' + entry.id} draggable="false" priority />
      ) : entry.data.image?.url ? (
        <Image src={entry.data.image.url} alt={entry.data.image?.alt ? entry.data.image?.alt : ''} id="title-image" transition:name={'image-' + entry.id} draggable="false" priority inferSize />
      ) : null
    }
    <Headline text={entry.data.title} class="pb-10" />
    <div class="markdown-content relative flex w-full flex-col gap-10 border-stone-300 px-3 py-3 text-left leading-7 sm:rounded-lg sm:border sm:px-6 sm:py-5 md:flex-row md:px-8 md:py-7 lg:rounded-xl dark:border-stone-700">
      <div class="flex shrink-0 flex-col gap-8 border-b border-stone-300 pb-10 md:max-w-xs md:border-r md:border-b-0 md:pr-10 md:pb-0 dark:border-stone-700">
        <div class="flex flex-col gap-1 font-semibold">
          <div class="flex items-center gap-1 text-sm opacity-70">
            <Icon name="heroicons:calendar-days" class="h-4 w-4 shrink-0" />
            {t('pages.events.when')}
          </div>
          <div class="pl-5 text-base">
            <span class="inline-block">
              {dateParts[0]}
              {dateParts[1] && <span class="mx-1 inline-block">-</span>}
            </span>
            <span class="inline-block">{dateParts[1] && dateParts[1]}</span>
            <br />
            <div class="text-xs opacity-70">
              (
              {entry.data.timeZone || 'GMT'}
              {entry.data.rrule && `, `}
              {
                entry.data.rrule && (
                  <span title={`RRULE: ${entry.data.rrule}`} class="cursor-help">
                    {t('pages.events.recurring')}
                  </span>
                )
              }
              )
            </div>
          </div>
        </div>
        {
          entry.data.location && (
            <div class="flex flex-col gap-1 font-semibold">
              <div class="flex items-center gap-1 text-sm opacity-70">
                <Icon name="heroicons:map-pin" class="h-4 w-4 shrink-0" />
                {t('pages.events.where')}
              </div>
              <div class="pl-5 text-base">{entry.data.location}</div>
            </div>
          )
        }
        {
          entry.data.organizer?.name && (
            <div class="flex flex-col gap-1 font-semibold">
              <div class="flex items-center gap-1 text-sm opacity-70">
                <Icon name="heroicons:user-circle" class="h-4 w-4 shrink-0" />
                {entry.data.organizer?.name}
              </div>
            </div>
          )
        }
        <div class="md:mt-8">
          <AddToCalendarButton
            name={entry.data.title}
            description={entry.data.description}
            start={entry.data.startDate}
            end={entry.data.endDate ?? entry.data.startDate}
            allDay={entry.data.allDay ?? false}
            timeZone={entry.data.timeZone}
            location={entry.data.location}
            rrule={entry.data.rrule}
            icsFile={entry.data.icsFile}
            language={locale}
            buttonStyle="default"
            organizer={entry.data.organizer}
            prokey={entry.prokey}
          />
        </div>
      </div>
      <div>
        {Content ? <Content /> : <Fragment set:html={bodyHtml} />}
      </div>
    </div>
  </div>
  <div class="mt-24">
    <h2 class="mb-5 text-2xl font-bold italic opacity-60 select-none sm:text-3xl">
      {t('pages.events.following-events')}
    </h2>
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        (async () => {
          const allEvents = (await getEvents(({ id, data }) => {
            // only show events that are not drafts and mind locale; limited to 3
            return !data.draft && id.startsWith(locale + '/');
          })) as CollectionEntry<'events'>[];
          const futureEvents = allEvents
            .filter((e) => e.data.startDate > entry.data.startDate)
            .sort((a, b) => a.data.startDate.getTime() - b.data.startDate.getTime())
            .slice(0, 3);
          return futureEvents.map((e) => (
            <a href={getLocaleUrl('events/detail/' + e.id.split('/').slice(-1)[0], locale)} class="text-text dark:text-text-dark xs:rounded-l-xl hover:border-primary rounded-lg border border-transparent bg-white px-4 py-3 font-semibold no-underline drop-shadow hover:drop-shadow-xl sm:nth-[n+3]:hidden lg:nth-[n+3]:block dark:bg-stone-800">
              <span>{e.data.title}</span>
              <span class="mt-4 flex items-start gap-2 text-sm opacity-80">
                <Icon name="heroicons:calendar-days" class="mt-px h-4 w-4 shrink-0" />
                {formatRange(e.data.startDate, e.data.endDate, e.data.allDay, locale)}
              </span>
              {e.data.location && (
                <span class="mt-2 flex items-start gap-2 text-sm opacity-80">
                  <Icon name="heroicons:map-pin" class="mt-px h-4 w-4 shrink-0" />
                  {e.data.location}
                </span>
              )}
            </a>
          ));
        })()
      }
    </div>
  </div>
</Layout>
