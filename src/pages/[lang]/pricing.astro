---
import Layout from "@layouts/default.astro";
import Headline from "@components/headline.astro";
import PricingTable from "@components/pricing/pricing-table.astro";
import { useTranslations } from "@utils/i18n";
import { themeConfig } from '~/theme.config';

export function getStaticPaths() {
  return themeConfig.i18n.locales
    .filter(lang => lang !== themeConfig.i18n.defaultLocale)
    .map(lang => ({
      params: { lang: lang }
    }));
}

const locale = Astro.params.lang;
const t = useTranslations(locale);
---

<Layout title={t('pages.pricing.title')} description={t('pages.pricing.description')} {locale}>
  <Headline text={t('pages.pricing.title')} class="pb-6" />
  <p class="mb-12 max-w-2xl text-lg text-stone-600 dark:text-stone-300">{t('pages.pricing.description')}</p>
  <PricingTable {locale} />
</Layout>
